@inherits LayoutComponentBase
@inject UserSession Session
@inject NavigationManager Nav

<div class="page">
    <main class="w-100 px-4 py-3">
        <div class="p-3 mb-3" style="background-color: #e8f5e9; color: #1b5e20; border-radius: 4px; border: 1px solid #c8e6c9;">
            <h5 class="fw-bold mb-0">Seleccione un módulo para agregar, visualizar, editar o eliminar datos y realizar cálculos.</h5>
            <small>Sesión activa: @(Session.IsAdmin ? "Administrador" : Session.NombreUsuario)</small>
        </div>

        <div class="d-flex gap-2 mb-4">
            @if (Session.IsAdmin)
            {
                <a href="/admin/usuarios" class="btn flex-fill btn-nav-dragon">Usuarios</a>
                <a href="/admin/productos" class="btn flex-fill btn-nav-dragon">Productos</a>
                <a href="/admin/menus" class="btn flex-fill btn-nav-dragon">Menús</a>
                <a href="/estadisticas-comparativas" class="btn flex-fill btn-nav-dragon">Estadísticas de Nutrición</a>
            }
            else
            {
                <a href="/admin/productos" class="btn flex-fill btn-nav-dragon">Catálogo de Productos</a>
                <a href="/admin/menus" class="btn flex-fill btn-nav-dragon">Mis Menús</a>
                <a href="/mi-progreso" class="btn flex-fill btn-nav-dragon">Mi Progreso (Estadísticas)</a>
            }
        </div>

        <article class="content">
            @Body
        </article>

        <div class="text-end mt-5">
            <button class="btn btn-sm btn-outline-danger fw-bold" @onclick="CerrarSesion">Cerrar sesión</button>
        </div>
    </main>
</div>

@code {
    private void CerrarSesion()
    {
        // Limpiamos la sesión por seguridad y redirigimos al Login
        Session.NombreUsuario = ""; 
        Nav.NavigateTo("/");
    }
}