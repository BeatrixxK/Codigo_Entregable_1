@inherits LayoutComponentBase
@using DragonNutrex.Web.Components.Layout
@inject UserSession Session
@inject NavigationManager Nav

<div class="page">
    <main class="w-100 px-4 py-3">
        <div class="p-3 mb-3" style="background-color: #e8f5e9; color: #1b5e20; border-radius: 4px; border: 1px solid #c8e6c9;">
            <h5 class="fw-bold mb-0">Seleccione un módulo para agregar, visualizar, editar o eliminar datos y realizar cálculos.</h5>
            <small>Sesión activa: @(Session.IsAdmin ? "Administrador" : Session.NombreUsuario)</small>
        </div>

        <div class="d-flex gap-2 mb-4">
            @if (Session.IsAdmin)
            {
                <a href="/admin/usuarios" class="btn flex-fill btn-nav-dragon shadow-sm">Usuarios</a>
                <a href="/admin/productos" class="btn flex-fill btn-nav-dragon shadow-sm">Productos</a>
                <a href="/admin/menus" class="btn flex-fill btn-nav-dragon shadow-sm">Menús</a>
                <a href="/estadisticas-comparativas" class="btn flex-fill btn-nav-dragon shadow-sm">Estadísticas</a>
            }
            else
            {
                <a href="/admin/productos" class="btn flex-fill btn-nav-dragon shadow-sm">Catálogo de Productos</a>
                <a href="/admin/menus" class="btn flex-fill btn-nav-dragon shadow-sm">Mis Menús</a>
                <a href="/mi-progreso" class="btn flex-fill btn-nav-dragon shadow-sm">Mi Progreso (Estadísticas)</a>
            }
        </div>

        <article class="content">
            <HeaderPerfil />

            @Body
        </article>

        <div class="text-end mt-5 pt-3 border-top">
            <button class="btn btn-sm btn-outline-danger fw-bold px-4" @onclick="CerrarSesion">
                🚪 Cerrar sesión
            </button>
        </div>
    </main>
</div>

@code {
    private void CerrarSesion()
    {
        // SOLUCIÓN ERROR CS0200: 
        // Solo limpiamos NombreUsuario. IsAdmin normalmente se calcula 
        // basado en el nombre, así que al vaciar el nombre, deja de ser Admin.
        Session.NombreUsuario = ""; 
        Nav.NavigateTo("/");
    }
}