@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Models
@using DragonNutrex.Web
@inject UserSession Session
@inject UsuarioController _usuarioController
@rendermode InteractiveServer

@if (usuario != null)
{
    <div class="card shadow-sm border-0 mb-4" style="background-color: #f1f8f1; border: 1px solid #c8e6c9 !important;">
        <div class="card-body py-3 px-4">
            @if (!enEdicion)
            {
                <div class="row align-items-center">
                    <div class="col-md-3">
                        <div class="mb-1"><span class="fw-bold" style="color: #1b5e20;">Usuario:</span> <span class="text-dark ms-1">@usuario.Nombre</span></div>
                        <div><span class="fw-bold" style="color: #1b5e20;">Dieta:</span> <span class="text-dark ms-1">@(usuario.TipoDieta ?? "Estándar")</span></div>
                    </div>
                    
                    <div class="col-md-3">
                        <div class="mb-1"><span class="fw-bold" style="color: #1b5e20;">Peso:</span> <span class="text-dark ms-1">@usuario.Peso.ToString("N1") kg</span></div>
                        <div><span class="fw-bold" style="color: #1b5e20;">Actividad:</span> <span class="text-dark ms-1">@actividadVisual</span></div>
                    </div>
                    
                    <div class="col-md-3">
                        <div class="mb-1"><span class="fw-bold" style="color: #1b5e20;">Altura:</span> <span class="text-dark ms-1">@usuario.Altura cm</span></div>
                        <div><span class="fw-bold" style="color: #1b5e20;">Objetivo:</span> <span class="text-dark ms-1">@objetivoVisual</span></div>
                    </div>

                    <div class="col-md-2 text-center border-start border-success border-opacity-25">
                        <div class="fw-bold small mb-1" style="color: #1b5e20;">Tu IMC</div>
                        <span class="badge shadow-sm px-3 py-2 fs-6" style="@ObtenerColorIMC(imcActual)">
                            @imcActual.ToString("N1") - @ObtenerTextoIMC(imcActual)
                        </span>
                    </div>

                    <div class="col-md-1 text-end">
                        <button class="btn btn-success fw-bold" @onclick="ActivarEdicion">Editar Perfil</button>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="small fw-bold text-success">Peso (kg)</label>
                        <input type="number" step="0.1" class="form-control form-control-sm" @bind="pesoEdit" @bind:after="RecalcularImcPreview" />
                    </div>
                    <div class="col-md-2">
                        <label class="small fw-bold text-success">Altura (cm)</label>
                        <input type="number" step="1" class="form-control form-control-sm" @bind="alturaEdit" @bind:after="RecalcularImcPreview" />
                    </div>
                    <div class="col-md-2">
                        <label class="small fw-bold text-success">Dieta</label>
                        <select class="form-select form-select-sm" @bind="dietaEdit">
                            <option value="Estándar">Estándar</option>
                            <option value="Vegana">Vegana</option>
                            <option value="Vegetariana">Vegetariana</option>
                            <option value="Keto">Keto</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="small fw-bold text-success">Actividad</label>
                        <select class="form-select form-select-sm" @bind="actividadEdit">
                            <option value="Sedentaria">Sedentaria</option>
                            <option value="Ligera">Ligera</option>
                            <option value="Moderada">Moderada</option>
                            <option value="Intensa">Intensa</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="small fw-bold text-success">Objetivo</label>
                        <select class="form-select form-select-sm" @bind="objetivoEdit">
                            <option value="Bajar peso">Bajar peso</option>
                            <option value="Mantener">Mantener</option>
                            <option value="Ganar músculo">Ganar músculo</option>
                        </select>
                    </div>
                    <div class="col-md-2 text-end d-flex gap-2 justify-content-end">
                        <button class="btn btn-sm btn-outline-secondary fw-bold" @onclick="CancelarEdicion">Cancelar</button>
                        <button class="btn btn-sm btn-success fw-bold" @onclick="GuardarPerfil">Guardar</button>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-warning shadow-sm py-2 mb-4">
        ⏳ <strong>Depuración de Componente:</strong> Intentando cargar el perfil... 
        <br/>Estado de Sesión: '@(Session == null || string.IsNullOrEmpty(Session.NombreUsuario) ? "SESIÓN VACÍA O NULA" : Session.NombreUsuario)'
    </div>
}

@code {
    /// <summary>
    /// Almacena la información del usuario actual que ha sido cargada desde la base de datos.
    /// Contiene todos los datos del perfil del usuario incluyendo peso, altura, tipo de dieta y objetivos nutricionales.
    /// </summary>
    private Usuario? usuario;
    
    /// <summary>
    /// Indica si el componente se encuentra actualmente en modo de edición de perfil.
    /// </summary>
    private bool enEdicion = false;
    
    /// <summary>
    /// Almacena el valor del Índice de Masa Corporal (IMC) actual del usuario.
    /// </summary>
    private decimal imcActual = 0;
    
    /// <summary>
    /// Almacena la vista previa del IMC mientras se editan los datos del usuario.
    /// </summary>
    private decimal imcPreview = 0;

    /// <summary>
    /// Variable temporal que almacena el peso del usuario durante la edición.
    /// </summary>
    private decimal pesoEdit;
    
    /// <summary>
    /// Variable temporal que almacena la altura del usuario durante la edición.
    /// </summary>
    private decimal alturaEdit;
    
    /// <summary>
    /// Variable temporal que almacena el tipo de dieta del usuario durante la edición.
    /// </summary>
    private string dietaEdit = "";
    
    /// <summary>
    /// Almacena el nivel de actividad física actual del usuario para su visualización.
    /// </summary>
    private string actividadVisual = "Sedentaria";
    
    /// <summary>
    /// Almacena el objetivo nutricional actual del usuario para su visualización.
    /// </summary>
    private string objetivoVisual = "Bajar peso";
    
    /// <summary>
    /// Variable temporal que almacena el nivel de actividad física durante la edición.
    /// </summary>
    private string actividadEdit = "Sedentaria";
    
    /// <summary>
    /// Variable temporal que almacena el objetivo nutricional durante la edición.
    /// </summary>
    private string objetivoEdit = "Bajar peso";

    /// <summary>
    /// Inicializa el componente de manera asincrónica. Invoca la carga de datos del usuario
    /// sin bloquear el hilo de ejecución principal. Se ejecuta automáticamente al renderizar el componente.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await CargarDatosUsuario();
    }

    /// <summary>
    /// Carga de manera asincrónica los datos del usuario desde la sesión activa y la base de datos.
    /// Obtiene todos los usuarios disponibles, busca el usuario actual por correo electrónico
    /// y calcula su Índice de Masa Corporal inicial. Actualiza la interfaz gráfica al completar la carga.
    /// </summary>
    private async Task CargarDatosUsuario()
    {
        if (Session != null && !string.IsNullOrEmpty(Session.NombreUsuario))
        {
            var usuarios = await _usuarioController.ObtenerTodosAsync();
            
            usuario = usuarios.FirstOrDefault(u => u.Correo.ToLower() == Session.NombreUsuario.ToLower());
            
            if (usuario != null) 
            {
                CalcularIMCOriginal();
                StateHasChanged();
            }
        }
    }

    /// <summary>
    /// Calcula el Índice de Masa Corporal (IMC) del usuario actual utilizando la fórmula estándar:
    /// IMC = Peso (kg) / (Altura (m))². Almacena el resultado en la variable imcActual
    /// para su visualización en la interfaz.
    /// </summary>
    private void CalcularIMCOriginal()
    {
        if (usuario != null && usuario.Altura > 0)
        {
            decimal alturaMetros = usuario.Altura / 100m;
            imcActual = usuario.Peso / (alturaMetros * alturaMetros);
        }
    }

    /// <summary>
    /// Activa el modo de edición del perfil de usuario. Copia los valores actuales
    /// del usuario a variables temporales de edición y genera una vista previa del IMC.
    /// Permite al usuario modificar peso, altura, tipo de dieta, nivel de actividad y objetivo.
    /// </summary>
    private void ActivarEdicion()
    {
        if (usuario == null) return;
        pesoEdit = usuario.Peso;
        alturaEdit = usuario.Altura;
        dietaEdit = usuario.TipoDieta ?? "Estándar";
        
        actividadEdit = actividadVisual;
        objetivoEdit = objetivoVisual;
        
        imcPreview = imcActual;
        enEdicion = true;
    }

    /// <summary>
    /// Recalcula la vista previa del Índice de Masa Corporal mientras el usuario modifica
    /// el peso y la altura en modo de edición. Utiliza la fórmula estándar de IMC para
    /// proporcionar retroalimentación inmediata sobre los cambios.
    /// </summary>
    private void RecalcularImcPreview()
    {
        if (alturaEdit > 0)
        {
            decimal alturaMetros = alturaEdit / 100m;
            imcPreview = pesoEdit / (alturaMetros * alturaMetros);
        }
    }

    /// <summary>
    /// Desactiva el modo de edición del perfil de usuario sin guardar los cambios realizados.
    /// Descarta todas las modificaciones temporales y retorna a la vista de solo lectura.
    /// </summary>
    private void CancelarEdicion() => enEdicion = false;

    /// <summary>
    /// Guarda los cambios del perfil del usuario modificados durante la edición.
    /// Actualiza el peso, altura, tipo de dieta, nivel de actividad y objetivo
    /// en la base de datos mediante el controlador. Recalcula el IMC y retorna
    /// a la vista de solo lectura tras completar la operación.
    /// </summary>
    private void GuardarPerfil()
    {
        if (usuario != null)
        {
            usuario.Peso = pesoEdit;
            usuario.Altura = alturaEdit;
            usuario.TipoDieta = dietaEdit;
            
            actividadVisual = actividadEdit;
            objetivoVisual = objetivoEdit;
            
            _usuarioController.ActualizarUsuario(usuario);
            CalcularIMCOriginal();
            enEdicion = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Genera una cadena de estilos CSS en línea que determina el color de fondo y el color de texto
    /// del badge de IMC según la clasificación de peso del usuario. Clasifica el IMC en cuatro categorías:
    /// bajo peso (amarillo), peso normal (verde), sobrepeso (naranja) y obesidad (rojo).
    /// </summary>
    /// <param name="imc">Valor decimal del Índice de Masa Corporal a clasificar.</param>
    /// <returns>Cadena de estilos CSS con colores correspondientes a la clasificación de IMC.</returns>
    private string ObtenerColorIMC(decimal imc)
    {
        if (imc < 18.5m) return "background-color: #ffc107; color: #000;"; 
        if (imc >= 18.5m && imc <= 24.9m) return "background-color: #28a745; color: #fff;"; 
        if (imc >= 25.0m && imc <= 29.9m) return "background-color: #fd7e14; color: #fff;"; 
        return "background-color: #dc3545; color: #fff;"; 
    }

    /// <summary>
    /// Genera la descripción textual correspondiente a la clasificación de Índice de Masa Corporal.
    /// Traduce los rangos numéricos de IMC en categorías de peso comprensibles para el usuario:
    /// bajo peso, peso normal, sobrepeso u obesidad.
    /// </summary>
    /// <param name="imc">Valor decimal del Índice de Masa Corporal a clasificar.</param>
    /// <returns>Cadena de texto que describe la clasificación de peso correspondiente al IMC.</returns>
    private string ObtenerTextoIMC(decimal imc)
    {
        if (imc < 18.5m) return "Bajo peso";
        if (imc >= 18.5m && imc <= 24.9m) return "Peso normal";
        if (imc >= 25.0m && imc <= 29.9m) return "Sobrepeso";
        return "Obesidad";
    }
}