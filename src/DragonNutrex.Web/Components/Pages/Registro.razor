@page "/registro"
@layout DragonNutrex.Web.Components.Layout.EmptyLayout
@inject NavigationManager Nav
@using DragonNutrex.App.Models
@using DragonNutrex.App.Controllers
@inject UsuarioController _usuarioController
@rendermode InteractiveServer

<PageTitle>Dragon Nutrex - Registro</PageTitle>

<div style="background-color: #a5d6a7; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif; padding: 20px;">
    <div class="text-center" style="width: 100%; max-width: 500px; background-color: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        
        <h2 style="color: #1b5e20; font-weight: bold; margin-bottom: 20px;">Únete a Dragon Nutrex 🐉</h2>

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-danger p-2 mb-3 shadow-sm border-0 fw-bold">@mensajeError</div>
        }

        <div class="mb-3 text-start">
            <label class="fw-bold" style="color: #1b5e20;">Nombre de Usuario</label>
            <input type="text" class="form-control" placeholder="Ej: Flora" @bind="nuevoUsuario.Nombre" />
        </div>

        @* 🔥 NUEVO CAMPO: Agregamos el Correo que es vital para tu sistema *@
        <div class="mb-3 text-start">
            <label class="fw-bold" style="color: #1b5e20;">Correo Electrónico</label>
            <input type="email" class="form-control" placeholder="ejemplo@correo.com" @bind="nuevoUsuario.Correo" />
        </div>

        <div class="mb-3 text-start">
            <label class="fw-bold" style="color: #1b5e20;">Contraseña</label>
            <input type="password" class="form-control" placeholder="Mínimo 6 caracteres" @bind="nuevoUsuario.Password" />
        </div>

        <div class="row mb-3">
            <div class="col text-start">
                <label class="fw-bold" style="color: #1b5e20;">Peso (kg)</label>
                <input type="number" step="0.1" class="form-control" @bind="nuevoUsuario.Peso" />
            </div>
            <div class="col text-start">
                <label class="fw-bold" style="color: #1b5e20;">Altura (cm)</label>
                <input type="number" step="0.1" class="form-control" @bind="nuevoUsuario.Altura" />
            </div>
        </div>

        <div class="mb-3 text-start">
            <label class="fw-bold" style="color: #1b5e20;">Nivel de Actividad</label>
            <select class="form-select" @bind="nuevoUsuario.Actividad">
                <option value="">Selecciona...</option>
                <option value="Sedentario">Sedentario</option>
                <option value="Ligero">Ligero</option>
                <option value="Moderado">Moderado</option>
                <option value="Intenso">Intenso</option>
            </select>
        </div>

        <div class="mb-3 text-start">
            <label class="fw-bold" style="color: #1b5e20;">Objetivo</label>
            <select class="form-select" @bind="nuevoUsuario.Objetivo">
                <option value="">Selecciona...</option>
                <option value="Perder Peso">Perder Peso</option>
                <option value="Mantener Peso">Mantener Peso</option>
                <option value="Ganar Masa Muscular">Ganar Masa Muscular</option>
            </select>
        </div>

        <div class="mb-4 text-start">
            <label class="fw-bold" style="color: #1b5e20;">Tipo de Dieta</label>
            <select class="form-select" @bind="nuevoUsuario.TipoDieta">
                <option value="">Selecciona...</option>
                <option value="Normal">Normal</option>
                <option value="Keto">Keto</option>
                <option value="Vegana">Vegana</option>
                <option value="Vegetariana">Vegetariana</option>
            </select>
        </div>

        <div class="d-grid gap-2">
            <button class="btn" style="background-color: #008f39; color: white; font-weight: bold; font-size: 1.1rem;" @onclick="RegistrarUsuario">
                Crear mi cuenta
            </button>
            <button class="btn btn-outline-secondary fw-bold" @onclick="VolverAlLogin">
                Cancelar
            </button>
        </div>

    </div>
</div>

@code {
    /// <summary>
    /// Instancia del nuevo usuario. Se agregan las propiedades en blanco para el placeholder.
    /// </summary>
    private Usuario nuevoUsuario = new Usuario 
    { 
        Id = Guid.NewGuid(),
        Nombre = "",
        Correo = "", // <-- Inicializado para el binding
        Password = "",
        Activo = true
    };
    
    private string mensajeError = "";

    private async Task RegistrarUsuario()
    {
        mensajeError = "";

        // Validamos también el correo
        if (string.IsNullOrWhiteSpace(nuevoUsuario.Nombre) || 
            string.IsNullOrWhiteSpace(nuevoUsuario.Correo) || 
            string.IsNullOrWhiteSpace(nuevoUsuario.Password))
        {
            mensajeError = "Nombre, correo y contraseña son obligatorios.";
            return;
        }

        try
        {
            var usuariosExistentes = await _usuarioController.ObtenerTodosAsync() ?? new List<Usuario>();
            
            // Validamos que el CORREO no esté repetido
            if (usuariosExistentes.Any(u => u.Correo != null && u.Correo.Trim().ToLower() == nuevoUsuario.Correo.Trim().ToLower()))
            {
                mensajeError = $"El correo '{nuevoUsuario.Correo}' ya está registrado.";
                return;
            }

            if (nuevoUsuario.Peso <= 0 || nuevoUsuario.Altura <= 0)
            {
                mensajeError = "El peso y la altura deben ser mayores a cero.";
                return;
            }

            if (string.IsNullOrWhiteSpace(nuevoUsuario.Actividad) || 
                string.IsNullOrWhiteSpace(nuevoUsuario.Objetivo) || 
                string.IsNullOrWhiteSpace(nuevoUsuario.TipoDieta))
            {
                mensajeError = "Por favor completa todos los campos desplegables.";
                return;
            }

            _usuarioController.CrearUsuario(nuevoUsuario);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            mensajeError = $"Ocurrió un inconveniente durante el registro: {ex.Message}";
        }
    }

    private void VolverAlLogin() => Nav.NavigateTo("/");
}