@page "/admin/menus"
@using DragonNutrex.Web
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Models
@inject UserSession Session
@inject UsuarioController _usuarioController
@inject MenuController _menuController
@inject ProductoController _productoController
@rendermode InteractiveServer

@* /// <summary>
/// Permite crear y editar menús nutricionales diarios.
/// </summary> *@

<PageTitle>@(Session.IsAdmin ? "Gestión de Menús" : "Mis Menús")</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color: #1b5e20;">@(Session.IsAdmin ? "Gestión de Menús" : "🍽️ Mi Diario de Comidas")</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-success fw-bold shadow-sm px-4" @onclick="GuardarMenu" disabled="@(usuarioSeleccionadoId == Guid.Empty)">
                💾 GUARDAR CAMBIOS
            </button>
        </div>
    </div>

    <div class="card mb-4 border-0 shadow-sm" style="background: #f8f9fa;">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="text-muted small fw-bold">@(Session.IsAdmin ? "Usuario Seleccionado" : "Mi Perfil")</label>
                    
                    @if (Session.IsAdmin)
                    {
                        <select class="form-select bg-white fw-bold text-success" @onchange="OnCambioUsuarioAdmin">
                            <option value="@Guid.Empty">-- Seleccione un usuario --</option>
                            @foreach (var u in listaUsuarios)
                            {
                                <option value="@u.Id" selected="@(u.Id == usuarioSeleccionadoId)">@u.Nombre (@u.Correo)</option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="input-group">
                            <span class="input-group-text bg-success text-white"><i class="bi bi-person-circle"></i></span>
                            <input type="text" class="form-control bg-white fw-bold text-dark" value="@nombreUsuarioActual" disabled />
                        </div>
                    }
                </div>
                <div class="col-md-5">
                    <label class="text-muted small fw-bold">Fecha del Menú</label>
                    <input type="date" class="form-control fw-bold" @bind="fechaMenu" @bind:after="CargarMenuDelDia" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary w-100 fw-bold shadow-sm" @onclick="LimpiarPantalla">Nuevo Día</button>
                </div>
            </div>
        </div>
    </div>

    @if (usuarioSeleccionadoId == Guid.Empty)
    {
        <div class="alert shadow-sm border-0 fw-bold d-flex align-items-center mt-5" style="background-color: #e3f2fd; color: #0d47a1;">
            <i class="bi bi-info-circle-fill fs-4 me-3"></i>
            <div>Por favor, selecciona un usuario para gestionar sus planes.</div>
        </div>
    }
    else
    {
        <div class="row g-2 mb-4 align-items-end p-3 rounded-2 shadow-sm" style="background-color: #ffffff; border: 1px solid #c8e6c9;">
            <div class="col-md-6">
                <label class="text-success small fw-bold mb-1">Seleccionar Producto</label>
                <select class="form-select shadow-sm" @bind="productoSeleccionadoId">
                    <option value="@Guid.Empty">-- Escoger alimento --</option>
                    @foreach (var p in listaProductos) 
                    { 
                        <option value="@p.Id">@p.Nombre (@p.Calorias kcal)</option> 
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="text-success small fw-bold mb-1">Cantidad (Porciones)</label>
                <input type="number" step="any" class="form-control shadow-sm" @bind="cantidadProducto" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-success w-100 fw-bold shadow-sm" @onclick="AgregarProductoAlMenu" disabled="@(productoSeleccionadoId == Guid.Empty || cantidadProducto <= 0)">
                    + Agregar
                </button>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-5">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="fw-bold mb-0 text-dark">
                    Menú del: <span class="text-success">@fechaMenu.ToString("dd/MM/yyyy")</span>
                </h5>
            </div>
            
            @if (menuActual != null && menuActual.Registros != null && menuActual.Registros.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead style="background-color: #f1f8f1;">
                            <tr>
                                <th class="ps-4">Producto</th>
                                <th style="width: 120px;" class="text-center">Cant.</th>
                                <th class="text-center">Kcal</th>
                                <th class="text-center">Quitar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reg in menuActual.Registros)
                            {
                                <tr @key="reg.ProductoId">
                                    <td class="ps-4 fw-bold text-dark">@reg.NombreProducto</td>
                                    <td>
                                        <input type="number" step="any" class="form-control form-control-sm text-center fw-bold shadow-sm" @bind="reg.Cantidad" @bind:after="() => RecalcularLineaYGuardar(reg)" />
                                    </td>
                                    <td class="text-center text-success fw-bold">@reg.Calorias.ToString("N1")</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger shadow-sm" @onclick="() => EliminarRegistro(reg)">🗑️</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot style="background-color: #e8f5e9;">
                            <tr class="fw-bold fs-6">
                                <td colspan="2" class="text-end pe-4" style="color: #1b5e20;">Total Consumido en este día:</td>
                                <td class="text-center text-dark">@menuActual.TotalCalorias.ToString("N1") kcal</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body text-center py-5">
                    <p class="text-muted mb-0">No has agregado alimentos para este día.</p>
                </div>
            }
        </div>

        <hr class="my-5" />

        <h4 class="fw-bold mb-3" style="color: #1b5e20;">📋 Historial de Menús Registrados</h4>
        <div class="table-responsive shadow-sm rounded-2">
            <table class="table table-hover bg-white align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Fecha</th>
                        <th>Calorías</th>
                        <th>Alimentos Principales</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (historialMenus.Any())
                    {
                        @foreach (var m in historialMenus.OrderByDescending(x => x.Fecha).ToList())
                        {
                            decimal totalKcal = m.TotalCalorias > 0 ? m.TotalCalorias : (m.Registros?.Sum(r => r.Calorias) ?? 0);

                            <tr @key="m.Id" style="cursor: pointer;" onmouseover="this.style.backgroundColor='#e8f5e9'" onmouseout="this.style.backgroundColor='transparent'" @onclick="() => AbrirVisor(m)">
                                <td class="ps-4 fw-bold" style="color: #1b5e20;">
                                    <i class="bi bi-calendar-check me-2"></i> @m.Fecha.ToString("dd/MM/yyyy")
                                </td>
                                <td><span class="badge bg-success px-3 py-2">@totalKcal.ToString("N0") kcal</span></td>
                                <td class="small text-muted">@string.Join(", ", m.Registros?.Select(r => r.NombreProducto).Take(3) ?? new List<string>())...</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary fw-bold me-2 shadow-sm" @onclick="() => ConfirmarEdicion(m)" @onclick:stopPropagation="true">✏️ Editar</button>
                                    <button class="btn btn-sm btn-outline-danger fw-bold shadow-sm" @onclick="() => EliminarMenuDesdeHistorial(m.Id)" @onclick:stopPropagation="true">🗑️ Borrar</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-journal-x fs-1 text-muted opacity-50 d-block mb-3"></i>
                                No hay menús guardados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarVisor && menuVisor != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); position: fixed; top:0; left:0; width:100%; height:100%; z-index: 9999;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header text-white" style="background-color: #1b5e20;">
                    <h5 class="modal-title fw-bold">🍽️ Menú del @menuVisor.Fecha.ToString("dd/MM/yyyy")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarVisor"></button>
                </div>
                <div class="modal-body p-0">
                    <table class="table table-bordered table-striped mb-0 text-center align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-start ps-3">Alimento</th>
                                <th style="width: 80px;">Cant.</th>
                                <th>Calorías</th>
                                <th>Proteína</th>
                                <th>Carbos</th>
                                <th>Grasas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (menuVisor.Registros != null && menuVisor.Registros.Any())
                            {
                                @foreach (var r in menuVisor.Registros)
                                {
                                    <tr @key="r.ProductoId">
                                        <td class="text-start ps-3 fw-bold" style="color: #1b5e20;">@r.NombreProducto</td>
                                        <td>@r.Cantidad</td>
                                        <td class="fw-bold">@r.Calorias.ToString("N1")</td>
                                        <td>@r.Proteinas.ToString("N1") g</td>
                                        <td>@r.Carbohidratos.ToString("N1") g</td>
                                        <td>@r.Grasas.ToString("N1") g</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot style="background-color: #e8f5e9; border-top: 3px solid #1b5e20;">
                            <tr class="fw-bold fs-6" style="color: #1b5e20;">
                                <td colspan="2" class="text-end pe-3">TOTALES DEL DÍA:</td>
                                <td>@menuVisor.TotalCalorias.ToString("N1")</td>
                                <td>@menuVisor.TotalProteinas.ToString("N1") g</td>
                                <td>@menuVisor.TotalCarbohidratos.ToString("N1") g</td>
                                <td>@menuVisor.TotalGrasas.ToString("N1") g</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="modal-footer justify-content-between" style="background-color: #f8f9fa;">
                    <button class="btn btn-outline-primary fw-bold" @onclick="() => { CerrarVisor(); ConfirmarEdicion(menuVisor); }">✏️ Editar este día</button>
                    <button class="btn btn-secondary fw-bold px-4" @onclick="CerrarVisor">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarModalEdicion && menuPendiente != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); position: fixed; top:0; left:0; width:100%; height:100%; z-index: 10000;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header text-dark" style="background-color: #ffc107;">
                    <h5 class="fw-bold mb-0">⚠️ Confirmar Edición</h5>
                    <button type="button" class="btn-close" @onclick="CancelarEdicion"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-2 fs-5">¿Deseas cargar el menú del <strong>@menuPendiente.Fecha.ToString("dd/MM/yyyy")</strong> en el editor principal?</p>
                </div>
                <div class="modal-footer" style="background-color: #f8f9fa;">
                    <button class="btn btn-secondary fw-bold px-4" @onclick="CancelarEdicion">Cancelar</button>
                    <button class="btn btn-warning text-dark fw-bold px-4" @onclick="EjecutarEdicion">Sí, Cargar Menú</button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarModalExito)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); position: fixed; top:0; left:0; width:100%; height:100%; z-index: 10001;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header text-white" style="background-color: #28a745;">
                    <h5 class="modal-title fw-bold">¡Operación Exitosa!</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModalExito = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <p class="fs-5 fw-bold text-success mb-0">@mensajeExito</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button class="btn btn-success fw-bold px-5" @onclick="() => mostrarModalExito = false">Aceptar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Usuario> listaUsuarios = new();
    private List<Producto> listaProductos = new();
    private List<Menu> historialMenus = new();
    
    private Guid usuarioSeleccionadoId = Guid.Empty;
    private string nombreUsuarioActual = "Cargando..."; 
    
    private Guid productoSeleccionadoId = Guid.Empty;
    private DateTime fechaMenu = DateTime.Today;
    private decimal cantidadProducto = 1;
    private Menu? menuActual;
    
    private bool mostrarVisor = false;
    private Menu? menuVisor;
    private bool mostrarModalEdicion = false;
    private Menu? menuPendiente;
    private bool mostrarModalExito = false;
    private string mensajeExito = "";

    protected override async Task OnInitializedAsync()
    {
        listaProductos = _productoController.ObtenerProductos() ?? new();
        listaUsuarios = await _usuarioController.ObtenerTodosAsync() ?? new();
        
        if (!Session.IsAdmin && !string.IsNullOrWhiteSpace(Session.NombreUsuario))
        {
            // Búsqueda a prueba de fallos
            var yo = listaUsuarios.FirstOrDefault(u => 
                (!string.IsNullOrEmpty(u.Correo) && u.Correo.Equals(Session.NombreUsuario, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrEmpty(u.Nombre) && u.Nombre.Equals(Session.NombreUsuario, StringComparison.OrdinalIgnoreCase))
            );
            
            if (yo != null) 
            { 
                usuarioSeleccionadoId = yo.Id;
                nombreUsuarioActual = $"{yo.Nombre} ({yo.Correo})";
                await CargarHistorialAsync(); 
            }
            else 
            {
                nombreUsuarioActual = "❌ Perfil no encontrado";
            }
        }
    }

    private async Task OnCambioUsuarioAdmin(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid idSeleccionado))
        {
            usuarioSeleccionadoId = idSeleccionado;
            
            if (usuarioSeleccionadoId != Guid.Empty)
            {
                fechaMenu = DateTime.Today; 
                await CargarHistorialAsync(); 
            }
            else
            {
                historialMenus.Clear();
                menuActual = null;
            }
        }
    }

    private async Task CargarHistorialAsync()
    {
        if (usuarioSeleccionadoId == Guid.Empty) return;

        // 🔥 AQUÍ ESTABA EL ERROR FATAL QUE CONGELABA LA PANTALLA
        // Eliminamos el Task.Run que causaba el Deadlock y usamos la versión puramente asincrónica:
        var todosLosMenus = await _menuController.ObtenerMenusAsync() ?? new List<Menu>();
        
        historialMenus = todosLosMenus.Where(m => m.UsuarioId == usuarioSeleccionadoId).ToList();
        CargarMenuDelDia();
    }

    private void CargarMenuDelDia()
    {
        if (usuarioSeleccionadoId == Guid.Empty) return;

        menuActual = historialMenus.FirstOrDefault(m => m.Fecha.Date == fechaMenu.Date) 
                     ?? new Menu { Id = Guid.NewGuid(), UsuarioId = usuarioSeleccionadoId, Fecha = fechaMenu.Date, Registros = new List<RegistroComida>() };
        
        if (menuActual.Registros == null) menuActual.Registros = new List<RegistroComida>();
        RecalcularTotalesGenerales();
    }

    private void AbrirVisor(Menu m) 
    { 
        menuVisor = m; 
        if (menuVisor.TotalCalorias <= 0 && menuVisor.Registros != null)
        {
            menuVisor.TotalCalorias = menuVisor.Registros.Sum(r => r.Calorias);
            menuVisor.TotalProteinas = menuVisor.Registros.Sum(r => r.Proteinas);
            menuVisor.TotalCarbohidratos = menuVisor.Registros.Sum(r => r.Carbohidratos);
            menuVisor.TotalGrasas = menuVisor.Registros.Sum(r => r.Grasas);
        }
        mostrarVisor = true; 
    }
    
    private void CerrarVisor() => mostrarVisor = false;
    private void ConfirmarEdicion(Menu m) { menuPendiente = m; mostrarModalEdicion = true; }
    private void CancelarEdicion() { mostrarModalEdicion = false; menuPendiente = null; }

    private void EjecutarEdicion()
    {
        if (menuPendiente != null) {
            fechaMenu = menuPendiente.Fecha;
            menuActual = menuPendiente;
            RecalcularTotalesGenerales();
        }
        CancelarEdicion();
    }

    private async Task GuardarMenu()
    {
        if (usuarioSeleccionadoId == Guid.Empty || menuActual == null) return;
        
        RecalcularTotalesGenerales();
        bool esUpdate = historialMenus.Any(m => m.Id == menuActual.Id);
        
        if (esUpdate) 
        { 
            _menuController.ActualizarMenu(menuActual); 
            mensajeExito = "El menú se ha actualizado exitosamente."; 
        }
        else 
        { 
            _menuController.CrearMenu(menuActual); 
            mensajeExito = "El nuevo menú se ha guardado exitosamente."; 
        }
        
        mostrarModalExito = true;
        await CargarHistorialAsync(); 
    }

    private void AgregarProductoAlMenu()
    {
        if (usuarioSeleccionadoId == Guid.Empty || menuActual == null) return;

        var p = listaProductos.FirstOrDefault(x => x.Id == productoSeleccionadoId);
        if (p != null) {
            if (menuActual.Registros == null) menuActual.Registros = new List<RegistroComida>();
            
            menuActual.Registros.Add(new RegistroComida { 
                ProductoId = p.Id, 
                NombreProducto = p.Nombre, 
                Cantidad = cantidadProducto, 
                Calorias = p.Calorias * cantidadProducto, 
                Proteinas = p.Proteinas * cantidadProducto, 
                Carbohidratos = p.Carbohidratos * cantidadProducto, 
                Grasas = p.Grasas * cantidadProducto 
            });
            
            RecalcularTotalesGenerales();
            productoSeleccionadoId = Guid.Empty; 
            cantidadProducto = 1;
        }
    }

    private async Task EliminarMenuDesdeHistorial(Guid id) 
    { 
        _menuController.EliminarMenu(id); 
        await CargarHistorialAsync(); 
    }

    private void RecalcularLineaYGuardar(RegistroComida reg) 
    { 
        var p = listaProductos.FirstOrDefault(x => x.Id == reg.ProductoId); 
        if (p != null) 
        { 
            reg.Calorias = p.Calorias * reg.Cantidad; 
            reg.Proteinas = p.Proteinas * reg.Cantidad; 
            reg.Carbohidratos = p.Carbohidratos * reg.Cantidad; 
            reg.Grasas = p.Grasas * reg.Cantidad; 
            RecalcularTotalesGenerales(); 
        } 
    }
    
    private void EliminarRegistro(RegistroComida r) 
    { 
        if (menuActual?.Registros != null)
        {
            menuActual.Registros.Remove(r); 
            RecalcularTotalesGenerales(); 
        }
    }

    private void RecalcularTotalesGenerales() 
    { 
        if (menuActual?.Registros == null) return; 
        menuActual.TotalCalorias = menuActual.Registros.Sum(r => r.Calorias); 
        menuActual.TotalProteinas = menuActual.Registros.Sum(r => r.Proteinas); 
        menuActual.TotalCarbohidratos = menuActual.Registros.Sum(r => r.Carbohidratos); 
        menuActual.TotalGrasas = menuActual.Registros.Sum(r => r.Grasas); 
    }

    private void LimpiarPantalla() 
    { 
        fechaMenu = DateTime.Today; 
        CargarMenuDelDia(); 
    }
}