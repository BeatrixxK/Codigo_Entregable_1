@page "/admin/menus"
@using DragonNutrex.Web
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Models
@inject UserSession Session
@inject UsuarioController _usuarioController
@inject MenuController _menuController
@inject ProductoController _productoController
@rendermode InteractiveServer

<PageTitle>Gestión de Menús</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color: #1b5e20;">Gestión de Menús</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-success fw-bold shadow-sm px-4" @onclick="GuardarMenu">
                💾 GUARDAR CAMBIOS
            </button>
        </div>
    </div>

    <div class="card mb-4 border-0 shadow-sm" style="background: #f8f9fa;">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="text-muted small fw-bold">Usuario Seleccionado</label>
                    
                    @if (Session.IsAdmin)
                    {
                        <select class="form-select bg-white" @onchange="OnCambioUsuarioAdmin">
                            <option value="@Guid.Empty">Seleccione un usuario...</option>
                            @foreach (var u in listaUsuarios)
                            {
                                // El selected asegura que si ya escogimos uno, se mantenga visible
                                <option value="@u.Id" selected="@(u.Id == usuarioSeleccionadoId)">@u.Nombre</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input type="text" class="form-control bg-white" value="@(listaUsuarios.FirstOrDefault(u => u.Id == usuarioSeleccionadoId)?.Nombre ?? "Cargando...")" disabled />
                    }
                </div>
                <div class="col-md-5">
                    <label class="text-muted small fw-bold">Fecha del Menú</label>
                    <input type="date" class="form-control" @bind="fechaMenu" @bind:after="CargarMenuDelDia" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-secondary w-100 fw-bold" @onclick="LimpiarPantalla">Nuevo / Limpiar</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-2 mb-4 align-items-end p-3 rounded-2 shadow-sm" style="background-color: #ffffff; border: 1px solid #dee2e6;">
        <div class="col-md-6">
            <label class="text-muted small fw-bold">Seleccionar Producto</label>
            <select class="form-select input-dragon" @bind="productoSeleccionadoId">
                <option value="@Guid.Empty">Escoger alimento...</option>
                @foreach (var p in listaProductos) 
                { 
                <option value="@p.Id">@p.Nombre (@p.Calorias kcal)</option> 
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="text-muted small fw-bold">Cantidad</label>
            <input type="number" step="any" class="form-control input-dragon" @bind="cantidadProducto" />
        </div>
        <div class="col-md-3">
            <button class="btn btn-dragon w-100 fw-bold" @onclick="AgregarProductoAlMenu">+ Agregar</button>
        </div>
    </div>

    @if (usuarioSeleccionadoId == Guid.Empty)
    {
        <div class="alert alert-info text-center mt-5 shadow-sm border-0 fw-bold">
            👆 Por favor, selecciona un usuario en la parte superior para ver y gestionar sus menús.
        </div>
    }
    else
    {
        @if (menuActual != null && menuActual.Registros != null && menuActual.Registros.Any())
        {
            <div class="table-responsive mb-5 shadow-sm rounded-2">
                <table class="table table-bordered align-middle mb-0 bg-white">
                    <thead style="background-color: #1b5e20; color: white;">
                        <tr>
                            <th>Producto</th>
                            <th style="width: 120px;">Cant.</th>
                            <th>Kcal</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reg in menuActual.Registros)
                        {
                            <tr @key="reg.ProductoId">
                                <td class="fw-bold">@reg.NombreProducto</td>
                                <td><input type="number" step="any" class="form-control form-control-sm text-center fw-bold" @bind="reg.Cantidad" @bind:after="() => RecalcularLineaYGuardar(reg)" /></td>
                                <td>@reg.Calorias.ToString("N1")</td>
                                <td class="text-center"><button class="btn btn-sm btn-outline-danger fw-bold" @onclick="() => EliminarRegistro(reg)">X</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <hr class="my-5" />

        <h4 class="fw-bold mb-3" style="color: #1b5e20;">📋 Historial de Menús Registrados</h4>
        <div class="table-responsive shadow-sm rounded-2">
            <table class="table table-hover bg-white align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Fecha (Click para ver)</th>
                        <th>Calorías</th>
                        <th>Alimentos</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (historialMenus.Any())
                    {
                        @foreach (var m in historialMenus.OrderByDescending(x => x.Fecha).ToList())
                        {
                            decimal totalKcal = m.TotalCalorias > 0 ? m.TotalCalorias : (m.Registros?.Sum(r => r.Calorias) ?? 0);

                            <tr @key="m.Id" style="cursor: pointer; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#e8f5e9'" onmouseout="this.style.backgroundColor='transparent'" @onclick="() => AbrirVisor(m)">
                                <td class="fw-bold" style="color: #1b5e20;">📁 @m.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@totalKcal.ToString("N1") kcal</td>
                                <td class="small text-muted">@string.Join(", ", m.Registros?.Select(r => r.NombreProducto).Take(2) ?? new List<string>())...</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-primary fw-bold me-1" @onclick="() => ConfirmarEdicion(m)" @onclick:stopPropagation="true">Editar</button>
                                    <button class="btn btn-sm btn-danger fw-bold" @onclick="() => EliminarMenuDesdeHistorial(m.Id)" @onclick:stopPropagation="true">Borrar</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">Este usuario aún no tiene menús registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarVisor && menuVisor != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); position: fixed; top:0; left:0; width:100%; height:100%; z-index: 9999;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header text-white" style="background-color: #1b5e20;">
                    <h5 class="modal-title fw-bold">🍽️ Menú del @menuVisor.Fecha.ToString("dd/MM/yyyy")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarVisor"></button>
                </div>
                <div class="modal-body p-0">
                    <table class="table table-bordered table-striped mb-0 text-center align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-start ps-3">Alimento</th>
                                <th style="width: 80px;">Cant.</th>
                                <th>Calorías</th>
                                <th>Proteína</th>
                                <th>Carbos</th>
                                <th>Grasas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (menuVisor.Registros != null && menuVisor.Registros.Any())
                            {
                                @foreach (var r in menuVisor.Registros)
                                {
                                    <tr @key="r.ProductoId">
                                        <td class="text-start ps-3 fw-bold" style="color: #1b5e20;">@r.NombreProducto</td>
                                        <td>@r.Cantidad</td>
                                        <td class="fw-bold">@r.Calorias.ToString("N1")</td>
                                        <td>@r.Proteinas.ToString("N1") g</td>
                                        <td>@r.Carbohidratos.ToString("N1") g</td>
                                        <td>@r.Grasas.ToString("N1") g</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No hay alimentos detallados en este menú.</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot style="background-color: #e8f5e9; border-top: 3px solid #1b5e20;">
                            <tr class="fw-bold fs-6" style="color: #1b5e20;">
                                <td colspan="2" class="text-end pe-3">TOTALES DEL DÍA:</td>
                                <td>@menuVisor.TotalCalorias.ToString("N1")</td>
                                <td>@menuVisor.TotalProteinas.ToString("N1") g</td>
                                <td>@menuVisor.TotalCarbohidratos.ToString("N1") g</td>
                                <td>@menuVisor.TotalGrasas.ToString("N1") g</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="modal-footer justify-content-between" style="background-color: #f8f9fa;">
                    <button class="btn btn-primary fw-bold" @onclick="() => { CerrarVisor(); ConfirmarEdicion(menuVisor); }">✏️ Editar este día</button>
                    <button class="btn btn-secondary fw-bold px-4" @onclick="CerrarVisor">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarModalEdicion && menuPendiente != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); position: fixed; top:0; left:0; width:100%; height:100%; z-index: 10000;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header text-dark" style="background-color: #ffc107;">
                    <h5 class="fw-bold mb-0">⚠️ Confirmar Edición</h5>
                    <button type="button" class="btn-close" @onclick="CancelarEdicion"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-2 fs-5">¿Deseas cargar el menú del <strong>@menuPendiente.Fecha.ToString("dd/MM/yyyy")</strong> en el editor?</p>
                    <p class="text-muted small mb-0">Los cambios actuales no guardados se perderán.</p>
                </div>
                <div class="modal-footer" style="background-color: #f8f9fa;">
                    <button class="btn btn-secondary fw-bold px-4" @onclick="CancelarEdicion">Cancelar</button>
                    <button class="btn btn-warning text-dark fw-bold px-4" @onclick="EjecutarEdicion">Sí, Cargar Menú</button>
                </div>
            </div>
        </div>
    </div>
}

@if (mostrarModalExito)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); position: fixed; top:0; left:0; width:100%; height:100%; z-index: 10001;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header text-white" style="background-color: #28a745;">
                    <h5 class="modal-title fw-bold">¡Operación Exitosa!</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModalExito = false"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <div class="mb-3"><span style="font-size: 3.5rem;">✅</span></div>
                    <p class="fs-5 fw-bold text-success mb-0">@mensajeExito</p>
                </div>
                <div class="modal-footer justify-content-center" style="background-color: #f8f9fa;">
                    <button class="btn btn-success fw-bold px-5" @onclick="() => mostrarModalExito = false">Aceptar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Usuario> listaUsuarios = new();
    private List<Producto> listaProductos = new();
    private List<Menu> historialMenus = new();
    private Guid usuarioSeleccionadoId = Guid.Empty;
    private Guid productoSeleccionadoId = Guid.Empty;
    private DateTime fechaMenu = DateTime.Today;
    private decimal cantidadProducto = 1;
    private Menu? menuActual;
    private string mensaje = "";
    private bool esError = false;

    // Modales
    private bool mostrarVisor = false;
    private Menu? menuVisor;
    private bool mostrarModalEdicion = false;
    private Menu? menuPendiente;
    private bool mostrarModalExito = false;
    private string mensajeExito = "";

    protected override void OnInitialized()
    {
        listaProductos = _productoController.ObtenerProductos() ?? new();
        listaUsuarios = _usuarioController.ObtenerUsuarios() ?? new();
        
        // Inicialización inteligente: 
        // Si no es admin, carga SU usuario obligatoriamente.
        // Si ES admin, lo dejamos en Guid.Empty para que él elija a quién revisar.
        if (!Session.IsAdmin)
        {
            var yo = listaUsuarios.FirstOrDefault(u => u.Nombre?.ToLower() == Session.NombreUsuario?.ToLower());
            if (yo != null) 
            { 
                usuarioSeleccionadoId = yo.Id; 
                CargarHistorial(); 
            }
        }
    }

    // Nuevo método para cuando el Admin cambia la lista desplegable
    private void OnCambioUsuarioAdmin(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid idSeleccionado))
        {
            usuarioSeleccionadoId = idSeleccionado;
            
            if (usuarioSeleccionadoId != Guid.Empty)
            {
                LimpiarPantalla(); // Resetea la fecha a HOY
                CargarHistorial(); // Trae los menús de la nueva persona
            }
            else
            {
                // Si vuelve a elegir "Seleccione un usuario...", limpiamos todo
                historialMenus.Clear();
                menuActual = null;
            }
        }
    }

    private void CargarHistorial()
    {
        if (usuarioSeleccionadoId == Guid.Empty) return;

        historialMenus = _menuController.ObtenerMenus()?.Where(m => m.UsuarioId == usuarioSeleccionadoId).ToList() ?? new();
        CargarMenuDelDia();
    }

    private void CargarMenuDelDia()
    {
        if (usuarioSeleccionadoId == Guid.Empty) return;

        menuActual = historialMenus.FirstOrDefault(m => m.Fecha.Date == fechaMenu.Date) 
                     ?? new Menu { UsuarioId = usuarioSeleccionadoId, Fecha = fechaMenu.Date, Registros = new List<RegistroComida>() };
        RecalcularTotalesGenerales();
    }

    private void AbrirVisor(Menu m) 
    { 
        menuVisor = m; 
        
        if (menuVisor.TotalCalorias <= 0 && menuVisor.Registros != null)
        {
            menuVisor.TotalCalorias = menuVisor.Registros.Sum(r => r.Calorias);
            menuVisor.TotalProteinas = menuVisor.Registros.Sum(r => r.Proteinas);
            menuVisor.TotalCarbohidratos = menuVisor.Registros.Sum(r => r.Carbohidratos);
            menuVisor.TotalGrasas = menuVisor.Registros.Sum(r => r.Grasas);
        }

        mostrarVisor = true; 
        StateHasChanged();
    }
    
    private void CerrarVisor() => mostrarVisor = false;
    private void ConfirmarEdicion(Menu m) { menuPendiente = m; mostrarModalEdicion = true; }
    private void CancelarEdicion() { mostrarModalEdicion = false; menuPendiente = null; }

    private void EjecutarEdicion()
    {
        if (menuPendiente != null) {
            fechaMenu = menuPendiente.Fecha;
            menuActual = menuPendiente;
            RecalcularTotalesGenerales();
        }
        CancelarEdicion();
    }

    private void GuardarMenu()
    {
        if (usuarioSeleccionadoId == Guid.Empty)
        {
            // Pequeña validación por si intentan guardar sin seleccionar usuario
            return; 
        }

        if (menuActual == null) return;
        RecalcularTotalesGenerales();
        bool esUpdate = _menuController.ObtenerMenus()?.Any(m => m.Id == menuActual.Id) ?? false;
        
        if (esUpdate) { _menuController.ActualizarMenu(menuActual); mensajeExito = "El menú se ha actualizado exitosamente."; }
        else { _menuController.CrearMenu(menuActual); mensajeExito = "El menú se ha creado exitosamente."; }
        
        mostrarModalExito = true;
        CargarHistorial();
    }

    private void AgregarProductoAlMenu()
    {
        if (usuarioSeleccionadoId == Guid.Empty) return;

        var p = listaProductos.FirstOrDefault(x => x.Id == productoSeleccionadoId);
        if (p != null) {
            menuActual!.Registros.Add(new RegistroComida { ProductoId = p.Id, NombreProducto = p.Nombre, Cantidad = cantidadProducto, Calorias = p.Calorias * cantidadProducto, Proteinas = p.Proteinas * cantidadProducto, Carbohidratos = p.Carbohidratos * cantidadProducto, Grasas = p.Grasas * cantidadProducto });
            RecalcularTotalesGenerales();
            productoSeleccionadoId = Guid.Empty; cantidadProducto = 1;
        }
    }

    private void EliminarMenuDesdeHistorial(Guid id) { _menuController.EliminarMenu(id); CargarHistorial(); }
    private void RecalcularLineaYGuardar(RegistroComida reg) { var p = listaProductos.FirstOrDefault(x => x.Id == reg.ProductoId); if (p != null) { reg.Calorias = p.Calorias * reg.Cantidad; reg.Proteinas = p.Proteinas * reg.Cantidad; reg.Carbohidratos = p.Carbohidratos * reg.Cantidad; reg.Grasas = p.Grasas * reg.Cantidad; RecalcularTotalesGenerales(); } }
    private void EliminarRegistro(RegistroComida r) { menuActual?.Registros.Remove(r); RecalcularTotalesGenerales(); }
    private void RecalcularTotalesGenerales() { if (menuActual?.Registros == null) return; menuActual.TotalCalorias = menuActual.Registros.Sum(r => r.Calorias); menuActual.TotalProteinas = menuActual.Registros.Sum(r => r.Proteinas); menuActual.TotalCarbohidratos = menuActual.Registros.Sum(r => r.Carbohidratos); menuActual.TotalGrasas = menuActual.Registros.Sum(r => r.Grasas); }
    private void LimpiarPantalla() { fechaMenu = DateTime.Today; CargarMenuDelDia(); }
}