@page "/admin/reportes"
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Services
@using DragonNutrex.App.Models

@inject UsuarioController _usuarioController
@inject EstadisticasNutricionController _statsController
@inject ExportacionService _exportService
@rendermode InteractiveServer

<PageTitle>Reportes Globales - Dragon Nutrex</PageTitle>

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <h2 class="text-danger mb-0"><i class="bi bi-graph-up"></i> Estadísticas del Sistema</h2>
        
        <BotonesExportacion 
            OnCsvClick="DescargarCSV" 
            OnTxtClick="DescargarTXT" 
            OnPdfClick="DescargarPDF" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">Producto Top (Hoy)</div>
                <div class="card-body text-center">
                    <h3>@_statsController.ObtenerProductoMasConsumido(DateTime.Today, DateTime.Today)</h3>
                    <p class="text-muted">Basado en los menús de hoy</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">Usuarios más activos</div>
                <ul class="list-group list-group-flush">
                    @foreach (var user in _statsController.ObtenerTopUsuariosConMasMenus(3))
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            @user.Key <span>@user.Value menús</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    // Almacenamos la lista de usuarios para que los reportes CSV y TXT la puedan usar
    private List<Usuario> listaUsuarios = new();

    protected override async Task OnInitializedAsync()
    {
        // Cargamos los datos de la base de datos al entrar a la pantalla
        listaUsuarios = await _usuarioController.ObtenerTodosAsync() ?? new();
    }

    // =====================================================
    // FUNCIONES QUE SE EJECUTAN AL HACER CLIC EN LOS BOTONES
    // =====================================================
    private async Task DescargarCSV() {
        var bytes = _exportService.GenerarCsvUsuarios(listaUsuarios); 
        await _exportService.DescargarArchivoEnNavegador($"Reporte_Usuarios_{DateTime.Now:yyyyMMdd}.csv", bytes);
    }

    private async Task DescargarTXT() {
        var bytes = _exportService.GenerarTxtUsuarios(listaUsuarios);
        await _exportService.DescargarArchivoEnNavegador($"Reporte_Usuarios_{DateTime.Now:yyyyMMdd}.txt", bytes);
    }

    private async Task DescargarPDF() {
        // Recopilamos los datos de las estadísticas para mandarlos al motor de PDF
        var dietas = _statsController.ObtenerPorcentajesDietas();
        var top = _statsController.ObtenerTopUsuariosConMasMenus();
        var productoString = _statsController.ObtenerProductoMasConsumido(DateTime.Today.AddDays(-30), DateTime.Today);
        
        // Creamos una lista segura para que el compilador no confunda los tipos de datos
        var listaUnProducto = new List<KeyValuePair<string, decimal>> {
            new KeyValuePair<string, decimal>(productoString, 0)
        };
        
        var bytes = _exportService.GenerarPdfEstadisticas(dietas, top, listaUnProducto, "Últimos 30 días");
        await _exportService.DescargarArchivoEnNavegador($"Reporte_Global_{DateTime.Now:yyyyMMdd}.pdf", bytes);
    }
}