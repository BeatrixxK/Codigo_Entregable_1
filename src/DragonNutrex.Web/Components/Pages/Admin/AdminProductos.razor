@page "/admin/productos"
@using DragonNutrex.Web
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Models
@using DragonNutrex.App.Services

@inject UserSession Session
@inject ProductoController _productoController
@inject ExportacionService _exportService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Gestión de Productos</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color: #1b5e20;">Gestión de Productos</h3>
        
        @if (Session.IsAdmin)
        {
            <BotonesExportacion 
                OnCsvClick="DescargarCSV" 
                OnTxtClick="DescargarTXT" 
                OnPdfClick="DescargarPDF" />
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje) && !mostrarModalExito)
    {
        <div class="alert @(esError ? "alert-danger" : "alert-success") py-2 rounded-1 fw-bold shadow-sm">
            @mensaje
        </div>
    }

    <div class="card border-0 shadow-sm mb-4" style="background: #f8f9fa;">
        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-md-4">
                    <label class="text-muted small fw-bold mb-1">Nombre del producto</label>
                    <input type="text" class="form-control input-dragon" @bind="nuevoProducto.Nombre" placeholder="Ej: Atún en agua" />
                </div>
                <div class="col-md-2">
                    <label class="text-muted small fw-bold mb-1">Calorías (kcal)</label>
                    <input type="number" step="any" class="form-control input-dragon" @bind="nuevoProducto.Calorias" />
                </div>
                <div class="col-md-2">
                    <label class="text-muted small fw-bold mb-1">Proteínas (g)</label>
                    <input type="number" step="any" class="form-control input-dragon" @bind="nuevoProducto.Proteinas" />
                </div>
                <div class="col-md-2">
                    <label class="text-muted small fw-bold mb-1">Carbohidratos (g)</label>
                    <input type="number" step="any" class="form-control input-dragon" @bind="nuevoProducto.Carbohidratos" />
                </div>
                <div class="col-md-2">
                    <label class="text-muted small fw-bold mb-1">Grasas (g)</label>
                    <input type="number" step="any" class="form-control input-dragon" @bind="nuevoProducto.Grasas" />
                </div>
            </div>

            <div class="d-flex gap-2">
                @if (productoSeleccionado == null)
                {
                    <button type="button" class="btn btn-dragon fw-bold px-4 shadow-sm" style="background-color: #1b5e20; color: white;" @onclick="Guardar">
                        💾 GUARDAR PRODUCTO NUEVO
                    </button>
                }
                else if (Session.IsAdmin)
                {
                    <button type="button" class="btn btn-primary fw-bold px-4 shadow-sm" @onclick="Guardar">
                        🔄 ACTUALIZAR CAMBIOS
                    </button>
                }

                @if (Session.IsAdmin && productoSeleccionado != null)
                {
                    <button type="button" class="btn btn-danger fw-bold rounded-1" @onclick="Eliminar">🗑️ ELIMINAR</button>
                }

                <button type="button" class="btn btn-outline-secondary fw-bold" @onclick="LimpiarFormulario">LIMPIAR / NUEVO</button>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white text-muted border-end-0">🔍</span>
                <input type="text" class="form-control border-start-0" 
                       placeholder="Buscar producto en la tabla..." 
                       value="@filtroBusqueda" 
                       @oninput="FiltrarTabla" />
            </div>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-2">
        <table class="table table-hover bg-white align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th class="text-center">Calorías</th>
                    <th class="text-center">Proteínas</th>
                    <th class="text-center">Carbos</th>
                    <th class="text-center">Grasas</th>
                </tr>
            </thead>
            <tbody>
                @if (productosFiltrados.Any())
                {
                    @foreach (var prod in productosFiltrados)
                    {
                        <tr @onclick="() => Seleccionar(prod)" 
                            style="@(Session.IsAdmin ? "cursor: pointer;" : "cursor: default;")" 
                            class="@(productoSeleccionado?.Id == prod.Id ? "table-success" : "")">
                            <td class="fw-bold" style="color: #1b5e20;">@prod.Nombre</td>
                            <td class="text-center">@prod.Calorias.ToString("N1")</td>
                            <td class="text-center">@prod.Proteinas.ToString("N1")g</td>
                            <td class="text-center">@prod.Carbohidratos.ToString("N1")g</td>
                            <td class="text-center">@prod.Grasas.ToString("N1")g</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No se encontraron productos con ese nombre.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (mostrarModalExito)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0, 0, 0, 0.7); position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 9999;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header text-white" style="background-color: #28a745;">
                    <h5 class="modal-title fw-bold">¡Operación Exitosa!</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body py-4 text-center">
                    <span style="font-size: 3.5rem;">✅</span>
                    <p class="mb-0 fs-5 fw-bold mt-2" style="color: #1b5e20;">@mensajeExito</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-success fw-bold px-5" @onclick="CerrarModal">Aceptar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Producto> listaProductos = new();
    private List<Producto> productosFiltrados = new();
    
    private Producto nuevoProducto = new Producto();
    private Producto? productoSeleccionado;
    
    private string mensaje = "";
    private bool esError = false;
    private bool mostrarModalExito = false;
    private string mensajeExito = "";
    private string filtroBusqueda = "";

    protected override void OnInitialized()
    {
        if (!Session.IsAdmin) Nav.NavigateTo("/");
        CargarLista();
    }

    private void CargarLista() 
    {
        var data = _productoController.ObtenerProductos();
        listaProductos = data != null ? data.ToList() : new List<Producto>();
        AplicarFiltro();
    }

    private void FiltrarTabla(ChangeEventArgs e)
    {
        filtroBusqueda = e.Value?.ToString() ?? "";
        AplicarFiltro();
    }

    private void AplicarFiltro()
    {
        if (string.IsNullOrWhiteSpace(filtroBusqueda))
        {
            productosFiltrados = listaProductos.ToList();
        }
        else
        {
            productosFiltrados = listaProductos
                .Where(p => p.Nombre.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void Seleccionar(Producto p)
    {
        if (!Session.IsAdmin) return;
        productoSeleccionado = p;
        nuevoProducto = new Producto { 
            Id = p.Id, Nombre = p.Nombre, Calorias = p.Calorias, 
            Proteinas = p.Proteinas, Carbohidratos = p.Carbohidratos, Grasas = p.Grasas 
        };
        mensaje = ""; 
    }

    private void Guardar()
    {
        if (string.IsNullOrWhiteSpace(nuevoProducto.Nombre)) 
        {
            MostrarError("El nombre del producto es obligatorio.");
            return;
        }

        try
        {
            bool nombreYaExiste = listaProductos.Any(p => 
                p.Nombre.Equals(nuevoProducto.Nombre, StringComparison.OrdinalIgnoreCase) && 
                p.Id != nuevoProducto.Id);

            if (nombreYaExiste)
            {
                MostrarError($"Ya existe un producto llamado '{nuevoProducto.Nombre}'.");
                return;
            }

            if (productoSeleccionado == null)
            {
                nuevoProducto.Id = Guid.NewGuid();
                _productoController.CrearProducto(nuevoProducto); 
                mensajeExito = $"Producto '{nuevoProducto.Nombre}' guardado correctamente.";
            }
            else
            {
                _productoController.ActualizarProducto(nuevoProducto); 
                mensajeExito = "Producto actualizado correctamente.";
            }

            mostrarModalExito = true;
            CargarLista();
        }
        catch (Exception ex)
        {
            MostrarError($"Error al guardar: {ex.Message}");
        }
    }

    private void Eliminar()
    {
        if (productoSeleccionado != null)
        {
            try
            {
                _productoController.EliminarProducto(productoSeleccionado.Id); 
                mensaje = "🗑️ Producto eliminado.";
                LimpiarFormulario();
                CargarLista();
            }
            catch (Exception ex)
            {
                MostrarError($"Error al eliminar: {ex.Message}");
            }
        }
    }

    // =====================================================
    // MÉTODOS DE EXPORTACIÓN
    // =====================================================
    private async Task DescargarCSV()
    {
        var bytes = _exportService.GenerarCsvProductos(listaProductos);
        await _exportService.DescargarArchivoEnNavegador($"Catalogo_Productos_{DateTime.Now:yyyyMMdd}.csv", bytes);
    }

    private async Task DescargarTXT()
    {
        var bytes = _exportService.GenerarTxtProductos(listaProductos);
        await _exportService.DescargarArchivoEnNavegador($"Catalogo_Productos_{DateTime.Now:yyyyMMdd}.txt", bytes);
    }

    private async Task DescargarPDF()
    {
        var bytes = _exportService.GenerarPdfProductos(listaProductos);
        await _exportService.DescargarArchivoEnNavegador($"Catalogo_Productos_{DateTime.Now:yyyyMMdd}.pdf", bytes);
    }

    private void MostrarError(string msj)
    {
        mensaje = "⚠️ " + msj;
        esError = true;
    }

    private void LimpiarFormulario() 
    { 
        nuevoProducto = new Producto(); 
        productoSeleccionado = null; 
        mensaje = "";
        esError = false;
    }

    private void CerrarModal()
    {
        mostrarModalExito = false;
        LimpiarFormulario();
        StateHasChanged();
    }
}