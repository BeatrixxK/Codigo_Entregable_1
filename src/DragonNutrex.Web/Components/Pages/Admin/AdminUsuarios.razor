@page "/admin/usuarios"
@using DragonNutrex.App.Models
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Services

@inject UsuarioController _usuarioController
@inject ExportacionService _exportService
@inject UserSession Session
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Gestión de Usuarios</PageTitle>

<div class="container-fluid mt-4" style="max-width: 1000px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0" style="color: #1b5e20;">👥 Mantenimiento de Usuarios</h3>
        
        @if (Session.IsAdmin)
        {
            <BotonesExportacion 
                OnCsvClick="DescargarCSV" 
                OnTxtClick="DescargarTXT" 
                OnPdfClick="DescargarPDF" />
        }
    </div>

    @if (!string.IsNullOrEmpty(mensajeAlerta))
    {
        <div class="alert alert-success py-2 fw-bold shadow-sm border-0 mb-3">
            @mensajeAlerta
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white text-muted border-end-0">🔍</span>
                <input type="text" class="form-control border-start-0" 
                       placeholder="Buscar usuario por nombre..." 
                       @bind="filtroBusqueda" 
                       @bind:event="oninput" />
            </div>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-2">
        <table class="table table-hover mb-0 bg-white align-middle">
            <thead style="background-color: #1b5e20; color: white;">
                <tr>
                    <th>Nombre / Usuario</th>
                    <th>Dieta</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (listaUsuarios.Any())
                {
                    var usuariosFiltrados = listaUsuarios
                        .Where(u => string.IsNullOrWhiteSpace(filtroBusqueda) || 
                                    u.Nombre.Contains(filtroBusqueda, StringComparison.OrdinalIgnoreCase))
                        .ToList();

                    if (usuariosFiltrados.Any())
                    {
                        @foreach (var user in usuariosFiltrados)
                        {
                            <tr>
                                <td class="fw-bold">@user.Nombre</td>
                                <td>@user.TipoDieta</td>
                                <td class="text-center">
                                    <span class="badge @(user.Activo ? "bg-success" : "bg-danger") rounded-pill">
                                        @(user.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm @(user.Activo ? "btn-outline-danger" : "btn-outline-success") fw-bold me-2" 
                                            @onclick="() => AlternarEstado(user)">
                                        @(user.Activo ? "Desactivar" : "Activar")
                                    </button>
                                    
                                    <button class="btn btn-sm btn-outline-warning fw-bold" 
                                            @onclick="() => ResetearPassword(user)">
                                        Reset Pwd
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No se encontraron usuarios que coincidan con la búsqueda.</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No hay usuarios registrados.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Usuario> listaUsuarios = new();
    private string mensajeAlerta = "";
    private string filtroBusqueda = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAdmin) 
        {
            Nav.NavigateTo("/"); 
            return;
        }
        
        await CargarUsuariosAsync();
    }

    private async Task CargarUsuariosAsync()
    {
        var todosLosUsuarios = await _usuarioController.ObtenerTodosAsync();
        
        listaUsuarios = todosLosUsuarios?
            .Where(u => u.Nombre?.ToLower() != "admin" && u.Correo?.ToLower() != "admin@admin.com")
            .ToList() ?? new List<Usuario>();
    }

    private void AlternarEstado(Usuario u)
    {
        u.Activo = !u.Activo;
        _usuarioController.ActualizarUsuario(u); 
        mensajeAlerta = $"El usuario {u.Nombre} ahora está {(u.Activo ? "Activo" : "Inactivo")}.";
    }

    private void ResetearPassword(Usuario u)
    {
        u.Password = "Dragon123*"; 
        _usuarioController.ActualizarUsuario(u); 
        mensajeAlerta = $"Contraseña de {u.Nombre} reseteada a: Dragon123*";
    }

    // =====================================================
    // MÉTODOS DE EXPORTACIÓN (Conectados al Service)
    // =====================================================
    private async Task DescargarCSV()
    {
        // Genera el archivo usando punto y coma (;) para evitar problemas con decimales
        var bytes = _exportService.GenerarCsvUsuarios(listaUsuarios);
        await _exportService.DescargarArchivoEnNavegador($"Directorio_Usuarios_{DateTime.Now:yyyyMMdd}.csv", bytes);
    }

    private async Task DescargarTXT()
    {
        var bytes = _exportService.GenerarTxtUsuarios(listaUsuarios);
        await _exportService.DescargarArchivoEnNavegador($"Directorio_Usuarios_{DateTime.Now:yyyyMMdd}.txt", bytes);
    }

    private async Task DescargarPDF()
    {
        var bytes = _exportService.GenerarPdfUsuarios(listaUsuarios);
        await _exportService.DescargarArchivoEnNavegador($"Directorio_Usuarios_{DateTime.Now:yyyyMMdd}.pdf", bytes);
    }
}