@page "/admin/usuarios"
@using DragonNutrex.App.Models
@using DragonNutrex.App.Controllers
@inject UsuarioController _usuarioController
@inject UserSession Session
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Gestión de Usuarios</PageTitle>

<div class="container-fluid mt-4" style="max-width: 1000px;">
    <h3 class="fw-bold mb-4" style="color: #1b5e20;">👥 Mantenimiento de Usuarios</h3>

    @if (!string.IsNullOrEmpty(mensajeAlerta))
    {
        <div class="alert alert-success py-2 fw-bold shadow-sm border-0 mb-3">
            @mensajeAlerta
        </div>
    }

    <div class="table-responsive shadow-sm rounded-2">
        <table class="table table-hover mb-0 bg-white align-middle">
            <thead style="background-color: #1b5e20; color: white;">
                <tr>
                    <th>Nombre / Usuario</th>
                    <th>Correo</th>
                    <th>Dieta</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (listaUsuarios.Any())
                {
                    @foreach (var user in listaUsuarios)
                    {
                        <tr>
                            <td class="fw-bold">@user.Nombre</td>
                            <td>@user.Correo</td>
                            <td>@user.TipoDieta</td>
                            <td class="text-center">
                                <span class="badge @(user.Activo ? "bg-success" : "bg-danger") rounded-pill">
                                    @(user.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm @(user.Activo ? "btn-outline-danger" : "btn-outline-success") fw-bold me-2" 
                                        @onclick="() => AlternarEstado(user)">
                                    @(user.Activo ? "Desactivar" : "Activar")
                                </button>
                                
                                <button class="btn btn-sm btn-outline-warning fw-bold" 
                                        @onclick="() => ResetearPassword(user)">
                                    Reset Pwd
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No hay usuarios registrados.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<Usuario> listaUsuarios = new();
    private string mensajeAlerta = "";

    protected override void OnInitialized()
    {
        if (!Session.IsAdmin) 
        {
            Nav.NavigateTo("/mi-progreso");
            return;
        }
        CargarUsuarios();
    }

    private void CargarUsuarios()
    {
        // Cargamos todos los usuarios (excepto el admin maestro si tienes uno)
        listaUsuarios = _usuarioController.ObtenerUsuarios()?
            .Where(u => u.Nombre.ToLower() != "admin")
            .ToList() ?? new List<Usuario>();
    }

    private void AlternarEstado(Usuario u)
    {
        u.Activo = !u.Activo;
        // Asumiendo que tu controlador tiene un método para guardar/actualizar en SQLite
        // _usuarioController.ActualizarUsuario(u); 
        
        mensajeAlerta = $"El usuario {u.Nombre} ahora está {(u.Activo ? "Activo" : "Inactivo")}.";
    }

    private void ResetearPassword(Usuario u)
    {
        u.Password = "Dragon123*"; // Contraseña temporal por defecto
        // _usuarioController.ActualizarUsuario(u); // Guardar en DB
        
        mensajeAlerta = $"Contraseña de {u.Nombre} reseteada a: Dragon123*";
    }
}