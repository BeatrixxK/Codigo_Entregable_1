@page "/estadisticas-comparativas"
@using DragonNutrex.Web
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Models
@inject UserSession Session
@inject UsuarioController _usuarioController
@inject EstadisticasNutricionController _statsController
@rendermode InteractiveServer

<PageTitle>Estadísticas de Nutrición</PageTitle>

<div class="container-fluid">
    <h3 class="fw-bold mb-4" style="color: #1b5e20;">Estadísticas de Nutrición</h3>

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger py-2 rounded-1 fw-bold">@mensajeError</div>
    }

    <div class="row g-3 mb-4 align-items-end">
        <div class="col-md-3">
            <label class="text-muted small fw-bold mb-1">Usuario</label>
            <select class="form-select input-dragon" @bind="usuarioSeleccionadoId" @bind:after="AlCambiarUsuario">
                <option value="@Guid.Empty">Seleccione un usuario...</option>
                @foreach (var u in listaUsuarios)
                {
                    <option value="@u.Id">@u.Nombre</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="text-muted small fw-bold mb-1">Dieta</label>
            <select class="form-select input-dragon" @bind="dietaSeleccionada">
                <option value="">Seleccione dieta...</option>
                <option value="Balanceada">Balanceada</option>
                <option value="Vegetariana">Vegetariana</option>
                <option value="Vegana">Vegana</option>
                <option value="Keto">Keto</option>
                <option value="Alta proteína">Alta proteína</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="text-muted small fw-bold mb-1">Fecha inicio</label>
            <input type="date" class="form-control input-dragon" @bind="fechaInicio" />
        </div>
        <div class="col-md-3">
            <label class="text-muted small fw-bold mb-1">Fecha fin</label>
            <input type="date" class="form-control input-dragon" @bind="fechaFin" />
        </div>
    </div>

    <div class="text-center mb-4">
        <button type="button" class="btn btn-dragon px-5 py-2 fs-5" @onclick="CalcularEstadisticas">
            Calcular Estadísticas de Nutrición
        </button>
    </div>

    @if (resumen != null && usuarioActual != null)
    {
        <div class="row g-3">
            <div class="col-md-6">
                <div class="p-3 rounded-2 h-100 shadow-sm" style="background-color: #e8f5e9; color: #1b5e20;">
                    <h5 class="fw-bold">Resumen general</h5>
                    <div><strong>Usuario:</strong> @usuarioActual!.Nombre</div>
                    <div><strong>Dieta seleccionada:</strong> @dietaSeleccionada</div>
                    <div><strong>Fecha inicio:</strong> @fechaInicio.ToString("dd/MM/yyyy")</div>
                    <div><strong>Fecha fin:</strong> @fechaFin.ToString("dd/MM/yyyy")</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 rounded-2 h-100 shadow-sm" style="background-color: #e8f5e9; color: #1b5e20;">
                    <h5 class="fw-bold">IMC y estado del usuario</h5>
                    <div><strong>IMC:</strong> @imc.ToString("F2")</div>
                    <div><strong>Categoría IMC:</strong> @categoriaImc</div>
                    <div class="mt-2 small text-muted">*(Calculado con Peso: @usuarioActual!.Peso kg / Altura: @usuarioActual!.Altura cm)*</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 rounded-2 h-100 shadow-sm" style="background-color: #e8f5e9; color: #1b5e20;">
                    <h5 class="fw-bold">Totales consumidos en el rango</h5>
                    <div><strong>Calorías totales:</strong> @resumen!.CaloriasTotalesConsumidas.ToString("F2")</div>
                    <div><strong>Proteínas totales:</strong> @resumen!.ProteinasTotalesConsumidas.ToString("F2") g</div>
                    <div><strong>Carbohidratos totales:</strong> @resumen!.CarbohidratosTotalesConsumidos.ToString("F2") g</div>
                    <div><strong>Grasas totales:</strong> @resumen!.GrasasTotalesConsumidas.ToString("F2") g</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 rounded-2 h-100 shadow-sm" style="background-color: #e8f5e9; color: #1b5e20;">
                    <h5 class="fw-bold">Objetivos según dieta</h5>
                    <div><strong>Calorías objetivo dieta:</strong> @resumen!.CaloriasObjetivoDieta.ToString("F2")</div>
                    <div><strong>Proteínas objetivo dieta:</strong> @resumen!.ProteinasObjetivoDieta.ToString("F2") g</div>
                    <div><strong>Carbohidratos objetivo dieta:</strong> @resumen!.CarbohidratosObjetivoDieta.ToString("F2") g</div>
                    <div><strong>Grasas objetivo dieta:</strong> @resumen!.GrasasObjetivoDieta.ToString("F2") g</div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="p-3 rounded-2 h-100 shadow-sm" style="background-color: #e8f5e9; color: #1b5e20;">
                    <h5 class="fw-bold">Promedio diario</h5>
                    <div><strong>Calorías promedio:</strong> @(diasCalculados > 0 ? (resumen!.CaloriasTotalesConsumidas / diasCalculados).ToString("F2") : "0")</div>
                    <div><strong>Proteínas promedio:</strong> @(diasCalculados > 0 ? (resumen!.ProteinasTotalesConsumidas / diasCalculados).ToString("F2") : "0") g</div>
                    <div><strong>Carbohidratos promedio:</strong> @(diasCalculados > 0 ? (resumen!.CarbohidratosTotalesConsumidos / diasCalculados).ToString("F2") : "0") g</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 rounded-2 h-100 shadow-sm" style="background-color: #e8f5e9; color: #1b5e20;">
                    <h5 class="fw-bold">Diferencia vs Dieta</h5>
                    @{
                        decimal difCalorias = resumen!.CaloriasTotalesConsumidas - resumen!.CaloriasObjetivoDieta;
                    }
                    <div><strong>Diferencia calorías:</strong> 
                        <span class="@(difCalorias > 0 ? "text-danger" : "text-success") fw-bold">
                            @(difCalorias > 0 ? "+" : "")@difCalorias.ToString("F2")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Usuario> listaUsuarios = new();
    private Guid usuarioSeleccionadoId;
    private string dietaSeleccionada = "";
    private DateTime fechaInicio = DateTime.Today.AddDays(-7);
    private DateTime fechaFin = DateTime.Today;
    
    // Resultados
    private dynamic? resumen; 
    private Usuario? usuarioActual;
    private string mensajeError = "";
    private int diasCalculados = 1;
    private decimal imc = 0;
    private string categoriaImc = "";

    protected override void OnInitialized()
    {
        try
        {
            listaUsuarios = _usuarioController.ObtenerUsuarios() ?? new List<Usuario>();
        }
        catch { /* Manejo silencioso en carga inicial */ }
    }

    private void AlCambiarUsuario()
    {
        var u = listaUsuarios.FirstOrDefault(x => x.Id == usuarioSeleccionadoId);
        if (u != null && !string.IsNullOrEmpty(u.TipoDieta))
        {
            dietaSeleccionada = u.TipoDieta.Trim();
        }
        else
        {
            dietaSeleccionada = "";
        }
    }

    private void CalcularEstadisticas()
    {
        if (usuarioSeleccionadoId == Guid.Empty)
        {
            mensajeError = "⚠️ Por favor, seleccione un usuario.";
            return;
        }
        if (string.IsNullOrEmpty(dietaSeleccionada))
        {
            mensajeError = "⚠️ Por favor, seleccione un tipo de dieta.";
            return;
        }
        if (fechaInicio > fechaFin)
        {
            mensajeError = "⚠️ La fecha de inicio no puede ser mayor a la fecha de fin.";
            return;
        }

        try
        {
            usuarioActual = listaUsuarios.FirstOrDefault(u => u.Id == usuarioSeleccionadoId);
            
            diasCalculados = (int)(fechaFin.Date - fechaInicio.Date).TotalDays + 1;

            resumen = _statsController.ObtenerResumen(usuarioSeleccionadoId, fechaInicio, fechaFin, dietaSeleccionada);
            
            CalcularIMC();
            mensajeError = "";
        }
        catch (Exception ex)
        {
            mensajeError = $"❌ Error al calcular estadísticas: {ex.Message}";
            resumen = null;
        }
    }

    private void CalcularIMC()
    {
        if (usuarioActual != null && usuarioActual.Altura > 0)
        {
            decimal alturaMetros = usuarioActual.Altura > 3 ? usuarioActual.Altura / 100m : usuarioActual.Altura;
            
            imc = usuarioActual.Peso / (alturaMetros * alturaMetros);

            if (imc < 18.5m) categoriaImc = "Bajo peso";
            else if (imc < 24.9m) categoriaImc = "Normal";
            else if (imc < 29.9m) categoriaImc = "Sobrepeso";
            else categoriaImc = "Obesidad";
        }
        else
        {
            imc = 0;
            categoriaImc = "Datos insuficientes";
        }
    }
}