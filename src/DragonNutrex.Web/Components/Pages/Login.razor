@page "/"
@layout DragonNutrex.Web.Components.Layout.EmptyLayout
@inject NavigationManager Nav
@using DragonNutrex.App.Models
@inject UserSession UserSession
@using DragonNutrex.App.Controllers
@inject UsuarioController _usuarioController
@rendermode InteractiveServer 

@* /// <summary>
/// Renderiza la interfaz principal de autenticación de Dragon Nutrex.
/// Gestiona el inicio de sesión seguro para usuarios regulares y administradores, 
/// e incluye la funcionalidad integrada para la recuperación y cambio de contraseñas.
/// </summary>
*@

<PageTitle>Dragon Nutrex - Inicia Sesión</PageTitle>

<div style="background-color: #a5d6a7; min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif;">
    <div class="text-center" style="width: 100%; max-width: 500px; padding: 20px;">
        
        <div class="mb-4">
            <img src="images/logo.png" alt="Dragon Nutrex Logo" style="max-height: 250px; width: auto; object-fit: contain;" />
        </div>

        @if (!modoRecuperacion)
        {
            <h2 style="color: #1b5e20; font-weight: bold; margin-bottom: 5px;">Bienvenido a Dragon Nutrex</h2>
            <h3 style="color: #1b5e20; font-weight: bold; margin-bottom: 30px;">Inicia sesión</h3>

            <div class="mb-3">
                <input type="email" class="form-control" placeholder="Correo Electrónico" @bind="usuarioInput"
                       style="background-color: #e0e0e0; border: none; height: 50px; border-radius: 4px; font-size: 1.1rem;" disabled="@estaCargando" />
            </div>
            <div class="mb-4">
                <input type="password" class="form-control" placeholder="Contraseña" @bind="passwordInput"
                       style="background-color: #000000; color: white; border: none; height: 50px; border-radius: 4px; font-size: 1.1rem;" disabled="@estaCargando" />
            </div>

            @if (!string.IsNullOrEmpty(mensajeSistema))
            {
                <div class="alert @(esExito ? "alert-success" : "alert-danger") p-2 mb-3" style="word-wrap: break-word; font-weight: bold;">@mensajeSistema</div>
            }

            <div class="d-flex justify-content-center gap-3 mb-4">
                <button class="btn d-flex align-items-center justify-content-center gap-2" style="background-color: #008f39; color: white; padding: 12px 40px; border-radius: 4px; font-weight: bold; font-size: 1.1rem; min-width: 160px;" @onclick="Entrar" disabled="@estaCargando">
                    @if (estaCargando)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span>Entrando...</span>
                    }
                    else
                    {
                        <span>Ingresar</span>
                    }
                </button>
                <button class="btn" style="background-color: #008f39; color: white; padding: 12px 40px; border-radius: 4px; font-weight: bold; font-size: 1.1rem;" disabled="@estaCargando" @onclick='() => Nav.NavigateTo("/registro")'>
                    Registrarse
                </button>
            </div>

            <a href="javascript:void(0)" @onclick="() => AlternarModo(true)" style="color: #1b5e20; text-decoration: none; font-weight: 500;">
                ¿Olvidaste tu contraseña?
            </a>
        }
        else
        {
            <h2 style="color: #1b5e20; font-weight: bold; margin-bottom: 5px;">Recuperar Contraseña</h2>
            <p style="color: #1b5e20; margin-bottom: 20px;">Ingresa tu correo para crear una nueva contraseña.</p>

            <div class="mb-3">
                <input type="email" class="form-control" placeholder="Correo Electrónico" @bind="usuarioRecuperacion"
                       style="background-color: #e0e0e0; border: none; height: 50px; border-radius: 4px; font-size: 1.1rem;" />
            </div>
            <div class="mb-4">
                <input type="password" class="form-control" placeholder="Nueva Contraseña" @bind="nuevaPassword"
                       style="background-color: #000000; color: white; border: none; height: 50px; border-radius: 4px; font-size: 1.1rem;" />
            </div>

            @if (!string.IsNullOrEmpty(mensajeSistema))
            {
                <div class="alert @(esExito ? "alert-success" : "alert-danger") p-2 mb-3 fw-bold">@mensajeSistema</div>
            }

            <div class="d-flex justify-content-center gap-3 mb-4">
                <button class="btn btn-secondary" style="padding: 12px 30px; border-radius: 4px; font-weight: bold; font-size: 1.1rem;" @onclick="() => AlternarModo(false)">
                    Cancelar
                </button>
                <button class="btn" style="background-color: #008f39; color: white; padding: 12px 30px; border-radius: 4px; font-weight: bold; font-size: 1.1rem;" @onclick="AutoresetearPassword">
                    Actualizar
                </button>
            </div>
        }
    </div>
</div>

@code {
    /// <summary>
    /// Almacena el correo electrónico introducido por el usuario en el formulario principal.
    /// </summary>
    private string usuarioInput = "";
    
    /// <summary>
    /// Almacena la contraseña introducida por el usuario en el formulario principal.
    /// </summary>
    private string passwordInput = "";
    
    /// <summary>
    /// Alterna la vista entre el formulario de inicio de sesión y la recuperación de credenciales.
    /// </summary>
    private bool modoRecuperacion = false;
    
    /// <summary>
    /// Almacena el correo electrónico ingresado para restablecer la contraseña.
    /// </summary>
    private string usuarioRecuperacion = "";
    
    /// <summary>
    /// Almacena la nueva contraseña solicitada por el usuario.
    /// </summary>
    private string nuevaPassword = "";
    
    /// <summary>
    /// Almacena los mensajes de retroalimentación emitidos por el sistema.
    /// </summary>
    private string mensajeSistema = "";
    
    /// <summary>
    /// Indica si la operación actual concluyó satisfactoriamente.
    /// </summary>
    private bool esExito = false;
    
    /// <summary>
    /// Controla el indicador visual de procesamiento y el bloqueo de botones.
    /// </summary>
    private bool estaCargando = false; 

    /// <summary>
    /// Alterna la vista principal limpiando los campos y mensajes activos.
    /// </summary>
    /// <param name="recuperar">Define si se muestra u oculta el panel de recuperación.</param>
    private void AlternarModo(bool recuperar)
    {
        modoRecuperacion = recuperar;
        mensajeSistema = "";
        usuarioRecuperacion = "";
        nuevaPassword = "";
        esExito = false;
    }

    /// <summary>
    /// Ejecuta el proceso de autenticación validando las credenciales mediante el controlador.
    /// Gestiona accesos maestros, verifica el estado de la cuenta y redirige al panel correspondiente.
    /// </summary>
    private async Task Entrar() 
    {
        mensajeSistema = "";
        esExito = false;

        if (string.IsNullOrWhiteSpace(usuarioInput) || string.IsNullOrWhiteSpace(passwordInput))
        {
            mensajeSistema = "Por favor ingrese su correo y contraseña.";
            return;
        }

        // Acceso maestro administrativo. Acepta "admin" o el estándar de reseteo "Dragon123"
        if (usuarioInput.ToLower() == "admin@admin.com" && (passwordInput == "admin" || passwordInput == "Dragon123"))
        {
            UserSession.IniciarSesion("admin@admin.com");
            Nav.NavigateTo("/admin/usuarios");
            return;
        }

        estaCargando = true;
        StateHasChanged(); 
        await Task.Delay(50); 

        try
        {
            // El controlador es el responsable de comparar la contraseña con el hash de BCrypt
            var userDb = await _usuarioController.AutenticarUsuarioAsync(usuarioInput, passwordInput);

            if (userDb == null)
            {
                mensajeSistema = "Correo o contraseña incorrectos.";
                return; 
            }

            if (!userDb.Activo)
            {
                mensajeSistema = "Esta cuenta ha sido desactivada por el administrador.";
                return;
            }

            UserSession.IniciarSesion(userDb.Correo);
            Nav.NavigateTo("/mi-progreso"); 
        }
        catch (Exception ex)
        {
            mensajeSistema = $"Ocurrió un error de conexión: {ex.Message}";
        }
        finally
        {
            estaCargando = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Restablece la contraseña del usuario previa validación de existencia y estado de la cuenta.
    /// Aplica encriptación BCrypt a la nueva credencial antes de enviarla a la base de datos Redis.
    /// </summary>
    private async Task AutoresetearPassword()
    {
        mensajeSistema = "";
        esExito = false;

        if (string.IsNullOrWhiteSpace(usuarioRecuperacion) || string.IsNullOrWhiteSpace(nuevaPassword))
        {
            mensajeSistema = "Todos los campos son obligatorios.";
            return;
        }

        var userDb = await _usuarioController.ObtenerUsuarioPorCorreoAsync(usuarioRecuperacion);

        if (userDb == null)
        {
            mensajeSistema = "El correo proporcionado no existe en nuestros registros.";
            return;
        }

        if (!userDb.Activo)
        {
            mensajeSistema = "No es posible recuperar la contraseña de una cuenta inactiva.";
            return;
        }

        // 🔥 CRÍTICO: La nueva contraseña debe encriptarse antes de guardar, sino el login fallará
        userDb.Password = BCrypt.Net.BCrypt.HashPassword(nuevaPassword);
        _usuarioController.ActualizarUsuario(userDb); 

        esExito = true;
        mensajeSistema = "¡Contraseña actualizada con éxito! Ya puedes iniciar sesión.";
        
        // Carga el correo en el input principal por comodidad y retorna al login
        usuarioInput = usuarioRecuperacion;
        passwordInput = "";
        usuarioRecuperacion = "";
        nuevaPassword = "";
        modoRecuperacion = false; 
    }
}