@page "/mi-progreso"
@using DragonNutrex.Web
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Models
@inject UserSession Session
@inject EstadisticasNutricionController _statsController
@inject UsuarioController _usuarioController
@inject MenuController _menuController
@rendermode InteractiveServer

<PageTitle>Mi Progreso Diario</PageTitle>

<div class="container-fluid mt-4" style="max-width: 900px;">
    <h3 class="fw-bold mb-4" style="color: #1b5e20;">📅 Seguimiento de Dieta</h3>

    @if (usuarioActual != null)
    {
        <div class="card mb-4 shadow-sm border-0" style="background-color: #f8f9fa;">
            <div class="card-body">
                <div class="row align-items-end g-3">
                    <div class="col-md-4">
                        <label class="fw-bold text-muted small">Fecha Inicio</label>
                        <input type="date" class="form-control input-dragon" @bind="fechaInicio" />
                    </div>
                    <div class="col-md-4">
                        <label class="fw-bold text-muted small">Fecha Fin</label>
                        <input type="date" class="form-control input-dragon" @bind="fechaFin" />
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-dragon w-100 fw-bold" @onclick="CargarProgreso">Consultar Historial</button>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(mensajeEstado))
        {
            <div class="alert alert-info py-2 fw-bold shadow-sm border-0 mb-3" style="background-color: #e3f2fd; color: #0d47a1;">
                @mensajeEstado
            </div>
        }

        <div class="table-responsive shadow-sm rounded-2">
            <table class="table table-hover mb-0 bg-white align-middle">
                <thead style="background-color: #1b5e20; color: white;">
                    <tr>
                        <th>Día (Click para ver detalle)</th>
                        <th>Consumo (kcal)</th>
                        <th>Objetivo (kcal)</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listaResumenes.Any())
                    {
                        @foreach (var dia in listaResumenes)
                        {
                            var item = dia; 
                            
                            <tr @key="item.Fecha" @onclick="() => VerDetalle(item.Fecha)" style="cursor: pointer; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='#e8f5e9'" onmouseout="this.style.backgroundColor='transparent'">
                                <td class="fw-bold" style="color: #1b5e20;">
                                    <i class="bi bi-folder2-open me-2"></i> @item.Fecha.ToString("dd/MM/yyyy")
                                </td>
                                <td class="fw-bold">@item.Consumido.ToString("N1")</td>
                                <td>@item.Meta.ToString("N1")</td>
                                <td class="text-center">
                                    <span class="badge @(item.Consumido > item.Meta ? "bg-danger" : "bg-success") px-3 py-2 rounded-pill">
                                        @(item.Consumido > item.Meta ? "Exceso" : "Adecuado")
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No hay datos en este rango de fechas.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarVisor && menuVisor != null)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.7); position: fixed; top:0; left:0; width:100%; height:100%; z-index: 9999;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header text-white" style="background-color: #1b5e20;">
                    <h5 class="modal-title fw-bold">🍽️ Menú del @menuVisor.Fecha.ToString("dd/MM/yyyy")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarVisor"></button>
                </div>
                
                <div class="modal-body p-0">
                    <table class="table table-bordered table-striped mb-0 text-center align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th class="text-start ps-3">Alimento</th>
                                <th style="width: 80px;">Cant.</th>
                                <th>Calorías</th>
                                <th>Proteína</th>
                                <th>Carbos</th>
                                <th>Grasas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (menuVisor.Registros != null && menuVisor.Registros.Any())
                            {
                                @foreach (var r in menuVisor.Registros)
                                {
                                    <tr @key="r.ProductoId">
                                        <td class="text-start ps-3 fw-bold" style="color: #1b5e20;">@r.NombreProducto</td>
                                        <td>@r.Cantidad</td>
                                        <td class="fw-bold">@r.Calorias.ToString("N1")</td>
                                        <td>@r.Proteinas.ToString("N1") g</td>
                                        <td>@r.Carbohidratos.ToString("N1") g</td>
                                        <td>@r.Grasas.ToString("N1") g</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No hay alimentos detallados en este menú.</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot style="background-color: #e8f5e9; border-top: 3px solid #1b5e20;">
                            <tr class="fw-bold fs-6" style="color: #1b5e20;">
                                <td colspan="2" class="text-end pe-3">TOTALES DEL DÍA:</td>
                                <td>@menuVisor.TotalCalorias.ToString("N1")</td>
                                <td>@menuVisor.TotalProteinas.ToString("N1") g</td>
                                <td>@menuVisor.TotalCarbohidratos.ToString("N1") g</td>
                                <td>@menuVisor.TotalGrasas.ToString("N1") g</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="modal-footer justify-content-end" style="background-color: #f8f9fa;">
                    <button type="button" class="btn btn-secondary fw-bold px-4" @onclick="CerrarVisor">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Usuario? usuarioActual;
    private DateTime fechaInicio = DateTime.Today.AddDays(-30);
    private DateTime fechaFin = DateTime.Today;
    private string mensajeEstado = "";
    
    private List<ResumenDiario> listaResumenes = new();

    // Variables del Visor
    private bool mostrarVisor = false;
    private Menu? menuVisor;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Session.NombreUsuario)) return;
        
        usuarioActual = _usuarioController.ObtenerUsuarios()?
            .FirstOrDefault(u => u.Nombre.ToLower() == Session.NombreUsuario.ToLower());
            
        if (usuarioActual != null) CargarProgreso();
    }

    private void CargarProgreso()
    {
        listaResumenes.Clear();
        if (usuarioActual == null) return;

        var menus = _menuController.ObtenerMenus()?
            .Where(m => m.UsuarioId.ToString().ToLower() == usuarioActual.Id.ToString().ToLower())
            .ToList() ?? new List<Menu>();
        
        foreach (var m in menus.Where(x => x.Fecha.Date >= fechaInicio.Date && x.Fecha.Date <= fechaFin.Date))
        {
            decimal meta = 0;
            try {
                var res = _statsController.ObtenerResumen(usuarioActual.Id, m.Fecha.Date, m.Fecha.Date.AddHours(23), usuarioActual.TipoDieta);
                meta = res?.CaloriasObjetivoDieta ?? 0;
            } catch { }

            decimal consumido = m.TotalCalorias > 0 ? m.TotalCalorias : (m.Registros?.Sum(r => r.Calorias) ?? 0);

            listaResumenes.Add(new ResumenDiario { Fecha = m.Fecha, Consumido = consumido, Meta = meta });
        }
        
        listaResumenes = listaResumenes.OrderByDescending(x => x.Fecha).ToList();
        mensajeEstado = $"✅ Datos cargados: {listaResumenes.Count} días encontrados.";
    }

    private void VerDetalle(DateTime fecha)
    {
        menuVisor = _menuController.ObtenerMenus()?
            .FirstOrDefault(m => m.UsuarioId == usuarioActual?.Id && m.Fecha.Date == fecha.Date);
            
        if (menuVisor != null) 
        {
            if (menuVisor.TotalCalorias <= 0)
            {
                var registrosSeguros = menuVisor.Registros ?? new List<RegistroComida>();
                menuVisor.TotalCalorias = registrosSeguros.Sum(r => r.Calorias);
                menuVisor.TotalProteinas = registrosSeguros.Sum(r => r.Proteinas);
                menuVisor.TotalCarbohidratos = registrosSeguros.Sum(r => r.Carbohidratos);
                menuVisor.TotalGrasas = registrosSeguros.Sum(r => r.Grasas);
            }

            mostrarVisor = true;
            StateHasChanged(); 
        }
    }

    private void CerrarVisor()
    {
        mostrarVisor = false;
        menuVisor = null;
        StateHasChanged(); 
    }

    private class ResumenDiario {
        public DateTime Fecha { get; set; }
        public decimal Consumido { get; set; }
        public decimal Meta { get; set; }
    }
}