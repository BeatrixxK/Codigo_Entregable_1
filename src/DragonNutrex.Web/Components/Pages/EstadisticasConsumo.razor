@page "/admin/estadisticas-consumo"
@using DragonNutrex.App.Models
@using DragonNutrex.App.Controllers
@using DragonNutrex.App.Services

@inject ExportacionService _exportService
@inject UsuarioController _usuarioController
@inject MenuController _menuController
@inject UserSession Session
@inject NavigationManager Nav
@rendermode InteractiveServer

@* /// <summary>
/// Renderiza el panel de control (Dashboard) de estadísticas globales de la plataforma.
/// Genera métricas generales como los productos más consumidos, la distribución de dietas 
/// entre los usuarios y el nivel de actividad de registro, permitiendo exportar 
/// estos resultados consolidados en distintos formatos.
/// </summary>
*@

<PageTitle>Estadísticas de Consumo</PageTitle>

<div class="container-fluid mt-4" style="max-width: 1000px;">
    <h3 class="fw-bold mb-4 text-center" style="color: #1b5e20;">📊 Estadísticas de Consumo Globales</h3>

    <div class="d-flex justify-content-center mb-4">
        <BotonesExportacion 
            OnCsvClick="DescargarCSV" 
            OnTxtClick="DescargarTXT" 
            OnPdfClick="DescargarPDF" />
    </div>

    <div class="card mb-4 shadow-sm border-0" style="background-color: #f8f9fa;">
        <div class="card-body row align-items-end g-3">
            <div class="col-md-4">
                <label class="fw-bold text-muted small">Fecha Inicio</label>
                <input type="date" class="form-control" @bind="fechaInicio" />
            </div>
            <div class="col-md-4">
                <label class="fw-bold text-muted small">Fecha Fin</label>
                <input type="date" class="form-control" @bind="fechaFin" />
            </div>
            <div class="col-md-4">
                <button class="btn btn-success w-100 fw-bold" @onclick="CalcularEstadisticas">Generar Reporte</button>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header text-white" style="background-color: #1b5e20;">
                    <h6 class="mb-0 fw-bold">🏆 Top 5 Productos Más Consumidos</h6>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var prod in topProductos)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @prod.Nombre
                            <span class="badge bg-success rounded-pill">@prod.Cantidad consumidos</span>
                        </li>
                    }
                    @if(!topProductos.Any()) { <li class="list-group-item text-muted text-center">No hay datos en este rango</li> }
                </ul>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header text-white" style="background-color: #008f39;">
                    <h6 class="mb-0 fw-bold">🥗 Porcentaje por Tipo de Dieta</h6>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var dieta in dietasPorcentaje)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @dieta.Nombre
                            <span class="badge bg-secondary rounded-pill">@dieta.Porcentaje.ToString("0.0")%</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-12">
            <div class="card shadow-sm border-0 mb-5">
                <div class="card-header text-white bg-dark">
                    <h6 class="mb-0 fw-bold">🔥 Usuarios más Activos (Menús Registrados)</h6>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th class="text-end">Total Menús</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in usuariosTopMenus)
                            {
                                <tr>
                                    <td>@user.NombreUsuario</td>
                                    <td class="text-end fw-bold">@user.TotalMenus</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Establece el límite inferior del rango de fechas para el cálculo de estadísticas globales.
    /// Se inicializa por defecto 30 días antes del día actual.
    /// </summary>
    private DateTime fechaInicio = DateTime.Today.AddDays(-30);
    
    /// <summary>
    /// Establece el límite superior del rango de fechas para el cálculo de estadísticas globales.
    /// Se inicializa por defecto en la fecha actual.
    /// </summary>
    private DateTime fechaFin = DateTime.Today;

    /// <summary>
    /// Almacena el resultado del procesamiento de los cinco productos más agregados en los menús.
    /// </summary>
    private List<TopProducto> topProductos = new();
    
    /// <summary>
    /// Almacena la distribución porcentual de los diferentes tipos de dieta registrados por los usuarios.
    /// </summary>
    private List<DietaStat> dietasPorcentaje = new();
    
    /// <summary>
    /// Almacena la lista de usuarios ordenados de mayor a menor según la cantidad de menús que han registrado.
    /// </summary>
    private List<UsuarioTop> usuariosTopMenus = new();
    
    /// <summary>
    /// Contiene la lista general de menús procesados que se enmarcan dentro del rango de fechas seleccionado.
    /// </summary>
    private List<Menu> menusFiltrados = new();
    
    /// <summary>
    /// Contiene el catálogo completo de usuarios registrados en el sistema para cruzar datos.
    /// </summary>
    private List<Usuario> todosLosUsuarios = new();

    /// <summary>
    /// Verifica los permisos de sesión al inicializar el componente. Redirige a los usuarios 
    /// no administradores a su panel personal y ejecuta el cálculo inicial de métricas.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAdmin) Nav.NavigateTo("/mi-progreso");
        await CalcularEstadisticas();
    }

    /// <summary>
    /// Procesa la totalidad de menús y usuarios de la base de datos para generar los indicadores 
    /// del tablero (dashboard). Filtra la información por fechas, agrupa los alimentos por frecuencia 
    /// de consumo, calcula la proporción de dietas y cuenta la participación de los usuarios.
    /// </summary>
    private async Task CalcularEstadisticas()
    {
        var todosLosMenus = _menuController.ObtenerMenus() ?? new List<Menu>();
        
        todosLosUsuarios = await _usuarioController.ObtenerTodosAsync() ?? new List<Usuario>();

        menusFiltrados = todosLosMenus
            .Where(m => m.Fecha.Date >= fechaInicio.Date && m.Fecha.Date <= fechaFin.Date)
            .ToList();

        topProductos = menusFiltrados
            .Where(m => m.Registros != null)
            .SelectMany(m => m.Registros!)
            .GroupBy(r => r.NombreProducto)
            .Select(g => new TopProducto { Nombre = g.Key, Cantidad = g.Sum(r => r.Cantidad) })
            .OrderByDescending(p => p.Cantidad)
            .Take(5)
            .ToList();

        int totalUsuarios = todosLosUsuarios.Count;
        if (totalUsuarios > 0)
        {
            dietasPorcentaje = todosLosUsuarios
                .GroupBy(u => u.TipoDieta)
                .Select(g => new DietaStat { 
                    Nombre = string.IsNullOrEmpty(g.Key) ? "No especificada" : g.Key, 
                    Porcentaje = (g.Count() * 100.0) / totalUsuarios 
                })
                .OrderByDescending(d => d.Porcentaje)
                .ToList();
        }

        usuariosTopMenus = menusFiltrados
            .GroupBy(m => m.UsuarioId)
            .Select(g => new UsuarioTop {
                NombreUsuario = todosLosUsuarios.FirstOrDefault(u => u.Id == g.Key)?.Nombre ?? "Usuario Desconocido",
                TotalMenus = g.Count()
            })
            .OrderByDescending(u => u.TotalMenus)
            .ToList();
    }

    // =====================================================
    // MÉTODOS PARA LOS BOTONES DE EXPORTACIÓN
    // =====================================================
    
    /// <summary>
    /// Invoca el servicio de exportación para generar y descargar un archivo CSV 
    /// que contiene la base de datos en crudo de los menús filtrados.
    /// </summary>
    private async Task DescargarCSV()
    {
        var bytes = _exportService.GenerarCsvMenus(menusFiltrados, todosLosUsuarios);
        await _exportService.DescargarArchivoEnNavegador($"Estadisticas_Data_{DateTime.Now:yyyyMMdd}.csv", bytes);
    }

    /// <summary>
    /// Invoca el servicio de exportación para generar y descargar un archivo de texto (TXT) 
    /// estructurado con los detalles de los menús filtrados.
    /// </summary>
    private async Task DescargarTXT()
    {
        var bytes = _exportService.GenerarTxtMenus(menusFiltrados, todosLosUsuarios);
        await _exportService.DescargarArchivoEnNavegador($"Estadisticas_Data_{DateTime.Now:yyyyMMdd}.txt", bytes);
    }

    /// <summary>
    /// Invoca el servicio de exportación para generar y descargar un reporte gerencial en formato PDF 
    /// que resume los indicadores principales del tablero (dashboard).
    /// </summary>
    private async Task DescargarPDF()
    {
        var dictDietas = dietasPorcentaje.ToDictionary(d => d.Nombre, d => d.Porcentaje);
        var listaTopUsuarios = usuariosTopMenus.Select(u => new KeyValuePair<string, int>(u.NombreUsuario, u.TotalMenus)).ToList();
        
        var listaTopProductos = topProductos.Select(p => new KeyValuePair<string, decimal>(p.Nombre, p.Cantidad)).ToList();
        
        var rango = $"{fechaInicio:dd/MM/yyyy} - {fechaFin:dd/MM/yyyy}";

        var bytes = _exportService.GenerarPdfEstadisticas(dictDietas, listaTopUsuarios, listaTopProductos, rango);
        await _exportService.DescargarArchivoEnNavegador($"Estadisticas_Reporte_{DateTime.Now:yyyyMMdd}.pdf", bytes);
    }

    /// <summary>
    /// Modelo auxiliar que estructura la información de un producto y la cantidad total de porciones consumidas.
    /// </summary>
    class TopProducto { public string Nombre { get; set; } = ""; public decimal Cantidad { get; set; } }
    
    /// <summary>
    /// Modelo auxiliar que estructura la información de un tipo de dieta y su distribución porcentual.
    /// </summary>
    class DietaStat { public string Nombre { get; set; } = ""; public double Porcentaje { get; set; } }
    
    /// <summary>
    /// Modelo auxiliar que asocia el nombre de un usuario con la cantidad total de menús que ha registrado.
    /// </summary>
    class UsuarioTop { public string NombreUsuario { get; set; } = ""; public int TotalMenus { get; set; } }
}