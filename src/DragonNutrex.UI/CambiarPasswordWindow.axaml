<!-- ===================================================== -->
<!-- VENTANA RESTABLECER CONTRASEÑA -->
<!-- Define la interfaz para cambiar la contraseña del usuario -->
<!-- ===================================================== -->

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DragonNutrex.UI.CambiarPasswordWindow"
        Width="400"
        Height="450"
        Title="Restablecer Contraseña"
        Background="#F4FBF5"
        WindowStartupLocation="CenterOwner">

    <!-- ===================================================== -->
    <!-- ESTILOS DE LA VENTANA -->
    <!-- Define la apariencia visual de textos, cajas y botones -->
    <!-- ===================================================== -->
    <Window.Styles>

        <!-- Estilo general para todos los TextBlock -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#1F5E2E"/>
        </Style>

        <!-- Estilo general para todos los TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F5E2E"/>
            <Setter Property="BorderBrush" Value="#B7DDBE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- Estilo general para todos los botones -->
        <Style Selector="Button">
            <Setter Property="Background" Value="#2E9E44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Estilo especial para botones con clase "cancelar" -->
        <Style Selector="Button.cancelar">
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="Foreground" Value="#1F5E2E"/>
        </Style>
    </Window.Styles>

    <!-- Contenedor principal con borde redondeado -->
    <Border BorderBrush="#B7DDBE" BorderThickness="1" CornerRadius="8" Margin="20" Padding="20" Background="White">
        
        <!-- Panel vertical que organiza todos los controles -->
        <StackPanel Spacing="15" VerticalAlignment="Center">
            
            <!-- Título principal de la ventana -->
            <TextBlock Text="Restablecer Contraseña" 
                       FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- Texto informativo para el usuario -->
            <TextBlock Text="Ingresa tu nombre de usuario y la nueva contraseña que deseas utilizar." 
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="14"/>

            <!-- Campo para escribir el nombre del usuario -->
            <TextBox x:Name="UsuarioRecuperarTextBox" Watermark="Nombre de Usuario"/>

            <!-- Campo para escribir la nueva contraseña -->
            <TextBox x:Name="NuevaPasswordTextBox" Watermark="Nueva Contraseña" PasswordChar="*"/>

            <!-- Campo para confirmar la nueva contraseña -->
            <TextBox x:Name="ConfirmarPasswordTextBox" Watermark="Confirmar Nueva Contraseña" PasswordChar="*"/>

            <!-- Texto para mostrar mensajes de error -->
            <TextBlock x:Name="MensajeErrorTextBlock" Foreground="Red" TextWrapping="Wrap" TextAlignment="Center" IsVisible="False"/>

            <!-- Panel horizontal para botones de acción -->
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,10,0,0">
                
                <!-- Botón para cancelar y cerrar la ventana -->
                <Button x:Name="CancelarButton" Content="Cancelar" Width="120" Classes="cancelar"/>

                <!-- Botón para guardar la nueva contraseña -->
                <Button x:Name="GuardarPasswordButton" Content="Guardar" Width="120"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>