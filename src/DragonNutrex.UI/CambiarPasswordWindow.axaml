<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DragonNutrex.UI.CambiarPasswordWindow"
        Width="400"
        Height="450"
        Title="Restablecer Contraseña"
        Background="#F4FBF5"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#1F5E2E"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F5E2E"/>
            <Setter Property="BorderBrush" Value="#B7DDBE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2E9E44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.cancelar">
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="Foreground" Value="#1F5E2E"/>
        </Style>
    </Window.Styles>

    <Border BorderBrush="#B7DDBE" BorderThickness="1" CornerRadius="8" Margin="20" Padding="20" Background="White">
        <StackPanel Spacing="15" VerticalAlignment="Center">
            
            <TextBlock Text="Restablecer Contraseña" 
                       FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Ingresa tu nombre de usuario y la nueva contraseña que deseas utilizar." 
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="14"/>

            <TextBox x:Name="UsuarioRecuperarTextBox" Watermark="Nombre de Usuario"/>
            <TextBox x:Name="NuevaPasswordTextBox" Watermark="Nueva Contraseña" PasswordChar="*"/>
            <TextBox x:Name="ConfirmarPasswordTextBox" Watermark="Confirmar Nueva Contraseña" PasswordChar="*"/>

            <TextBlock x:Name="MensajeErrorTextBlock" Foreground="Red" TextWrapping="Wrap" TextAlignment="Center" IsVisible="False"/>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="CancelarButton" Content="Cancelar" Width="120" Classes="cancelar"/>
                <Button x:Name="GuardarPasswordButton" Content="Guardar" Width="120"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>