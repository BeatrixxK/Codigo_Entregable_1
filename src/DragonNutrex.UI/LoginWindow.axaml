<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DragonNutrex.UI.LoginWindow"
        Width="500"
        Height="750"
        Title="Login DragonNutrex"
        Background="White"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,Auto" VerticalAlignment="Top">

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,0" Spacing="10">
            
            <Image Source="avares://DragonNutrex.UI/Images/logo.png"
                   Width="300" Stretch="Uniform" HorizontalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#b4dcb8" CornerRadius="18" Padding="26" Margin="24,-80,24,20" VerticalAlignment="Top">
            
            <StackPanel Spacing="16">

                <TextBlock FontSize="28" FontWeight="Bold" Foreground="#11582d" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center">
                    Bienvenido a Dragon Nutrex
                    <LineBreak/>
                    Inicia sesión
                </TextBlock>

                <TextBox x:Name="UsuarioTextBox" 
                         Watermark="Usuario" 
                         Background="#EAEAEA" 
                         Foreground="Gray" 
                         BorderBrush="#CCCCCC"/>

                <TextBox x:Name="PasswordTextBox" 
                         Watermark="Contraseña" 
                         PasswordChar="*" 
                         Background="#EAEAEA" 
                         Foreground="Gray" 
                         BorderBrush="#CCCCCC"/>

                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    
                    <Button x:Name="LoginButton" 
                            Content="Ingresar" 
                            Width="140" 
                            Background="#2E9E44" 
                            Foreground="White" 
                            HorizontalContentAlignment="Center"
                            Click="BtnIngresar_Click"/>
                    
                    <Button x:Name="RegistrarseButton" 
                            Content="Registrarse" 
                            Width="140" 
                            Background="#2E9E44" 
                            Foreground="White" 
                            HorizontalContentAlignment="Center"
                            Click="BtnRegistrarse_Click"/>
                </StackPanel>

                <Button x:Name="OlvidastePasswordButton" 
                        Content="¿Olvidaste tu contraseña?" 
                        Background="Transparent" 
                        Foreground="#11582d" 
                        FontWeight="Bold" 
                        HorizontalAlignment="Center" 
                        Margin="0,5,0,0"/>

                <TextBlock x:Name="ErrorTextBlock" 
                           Foreground="Red" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center"/>
            
            </StackPanel>
        </Border>
    </Grid>
</Window>