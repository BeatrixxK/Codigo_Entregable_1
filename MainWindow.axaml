<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaControls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        mc:Ignorable="d"
        x:Class="DragonNutrex.UI.MainWindow"
        Width="1000"
        Height="650"
        Title="DragonNutrex">

    <StackPanel Margin="20" Spacing="10">

        <TextBlock Text="Registro de Usuario" FontSize="24"/>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
            <TextBox x:Name="NombreTextBox" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" Watermark="Nombre"/>
            <TextBox x:Name="PesoTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Watermark="Peso"/>

            <TextBox x:Name="AlturaTextBox" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" Watermark="Altura"/>
            <TextBox x:Name="ActividadTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Watermark="Actividad"/>

            <TextBox x:Name="ObjetivoTextBox" Grid.Row="2" Grid.Column="0" Margin="0,0,10,10" Watermark="Objetivo"/>
            <TextBox x:Name="TipoDietaTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Watermark="Tipo Dieta"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button x:Name="GuardarButton" Content="Guardar" Width="140"/>
            <Button x:Name="EliminarButton" Content="Eliminar seleccionado" Width="180"/>
            <Button x:Name="LimpiarButton" Content="Limpiar" Width="120"/>
        </StackPanel>

        <TextBlock Text="Usuarios registrados:" Margin="0,20,0,0" FontSize="18"/>

        <avaloniaControls:DataGrid x:Name="UsuariosDataGrid"
                                   Height="320"
                                   AutoGenerateColumns="False"
                                   IsReadOnly="True">
            <avaloniaControls:DataGrid.Columns>
                <avaloniaControls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                <avaloniaControls:DataGridTextColumn Header="Peso" Binding="{Binding Peso}" Width="*"/>
                <avaloniaControls:DataGridTextColumn Header="Altura" Binding="{Binding Altura}" Width="*"/>
                <avaloniaControls:DataGridTextColumn Header="Actividad" Binding="{Binding Actividad}" Width="2*"/>
                <avaloniaControls:DataGridTextColumn Header="Objetivo" Binding="{Binding Objetivo}" Width="2*"/>
                <avaloniaControls:DataGridTextColumn Header="Tipo Dieta" Binding="{Binding TipoDieta}" Width="2*"/>
            </avaloniaControls:DataGrid.Columns>
        </avaloniaControls:DataGrid>

    </StackPanel>
</Window>